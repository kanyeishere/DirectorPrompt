<UserControl x:Class="DirectorPrompt.Views.Components.DirectiveInputControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:loc="clr-namespace:DirectorPrompt.Localization">
    <StackPanel x:Name="RootPanel">
        <ItemsControl ItemsSource="{Binding Directives}"
                      Margin="0,0,0,8">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,2"
                            Padding="10,6"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <!-- 有 TTL 指令: 两行布局, 第一行类型+TTL+按钮, 第二行内容 -->
                            <StackPanel IsVisible="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TypeDisplay}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <fa:FANumberBox Grid.Column="1"
                                                    Width="180"
                                                    Value="{Binding TTL, TargetNullValue=5}"
                                                    Minimum="1"
                                                    Maximum="999"
                                                    SmallChange="1"
                                                    LargeChange="5"
                                                    Margin="0,0,4,0"
                                                    VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding [Directive.Input.TTLUnit], Source={x:Static loc:Loc.Instance}}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                                        <Button Padding="12,8"
                                                MinWidth="36"
                                                Margin="2,0"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="↑" FontSize="14" />
                                        </Button>
                                        <Button Padding="12,8"
                                                MinWidth="36"
                                                Margin="2,0"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="↓" FontSize="14" />
                                        </Button>
                                        <Button Padding="12,8"
                                                MinWidth="36"
                                                Margin="2,0"
                                                Command="{Binding DataContext.RemoveDirectiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="✕" FontSize="14" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <TextBox Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinLines="1"
                                         MaxLines="3"
                                         BorderThickness="0"
                                         Background="Transparent" />
                            </StackPanel>
                            <!-- 无 TTL 指令: 单行布局 -->
                            <Grid
                                IsVisible="{Binding HasTTL, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TypeDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding Content}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         MinLines="1"
                                         MaxLines="3"
                                         VerticalAlignment="Center"
                                         BorderThickness="0"
                                         Background="Transparent" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button Padding="12,8"
                                            MinWidth="36"
                                            Margin="2,0"
                                            Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="↑" FontSize="14" />
                                    </Button>
                                    <Button Padding="12,8"
                                            MinWidth="36"
                                            Margin="2,0"
                                            Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="↓" FontSize="14" />
                                    </Button>
                                    <Button Padding="12,8"
                                            MinWidth="36"
                                            Margin="2,0"
                                            Command="{Binding DataContext.RemoveDirectiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="✕" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <StackPanel Margin="0,4,0,0">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0"
                          Width="200"
                          SelectedIndex="0"
                          SelectionChanged="OnDirectiveTypeChanged"
                          Margin="0,0,4,0">
                    <ComboBoxItem Content="{Binding [Directive.Type.Plot], Source={x:Static loc:Loc.Instance}}" />
                    <ComboBoxItem Content="{Binding [Directive.Type.Tone], Source={x:Static loc:Loc.Instance}}" />
                    <ComboBoxItem
                        Content="{Binding [Directive.Type.TemporaryConstraint], Source={x:Static loc:Loc.Instance}}" />
                    <ComboBoxItem Content="{Binding [Directive.Type.SceneChange], Source={x:Static loc:Loc.Instance}}" />
                </ComboBox>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            IsVisible="{Binding InputHasTTL, Converter={StaticResource BoolToVisibility}}">
                    <Border Width="1"
                            Margin="8,2"
                            Background="{DynamicResource ControlElevationBorderBrush}" />
                    <TextBlock Text="{Binding [Navigation.InputTTL], Source={x:Static loc:Loc.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <fa:FANumberBox Width="150"
                                    Value="{Binding InputTTL, TargetNullValue=5}"
                                    Minimum="1"
                                    Maximum="999"
                                    SmallChange="1"
                                    LargeChange="5" />
                </StackPanel>
            </Grid>

            <TextBox Margin="0,0,0,4"
                     Text="{Binding InputContent}"
                     TextWrapping="Wrap"
                     MaxHeight="300"
                     AcceptsReturn="True" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button Width="150"
                        Margin="0,0,4,0"
                        Padding="12,6"
                        Command="{Binding AddDirectiveCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Add" />
                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                    </StackPanel>
                </Button>
                <Border Width="1"
                        Margin="4,4"
                        Background="{DynamicResource ControlElevationBorderBrush}"
                        IsVisible="{Binding ShowSendButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}" />
                <Button Width="150"
                        Margin="4,0,0,0"
                        Padding="16,6"
                        IsVisible="{Binding ShowSendButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding SendCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        IsEnabled="{Binding IsProcessing, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Send" />
                        <TextBlock Text="{Binding [Dialog.SendDirective], Source={x:Static loc:Loc.Instance}}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
