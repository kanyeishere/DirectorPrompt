<UserControl x:Class="DirectorPrompt.Views.Components.PhaseEditControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:DirectorPrompt.Localization"
             xmlns:components="clr-namespace:DirectorPrompt.Views.Components">
    <StackPanel x:Name="RootPanel">
        <Grid Margin="0,12,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding [State.Attribute.Phases], Source={x:Static loc:Loc.Instance}}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ui:Button Grid.Column="1"
                       Content="{Binding [State.Attribute.AddPhase], Source={x:Static loc:Loc.Instance}}"
                       Icon="{ui:SymbolIcon Symbol=Add24}"
                       Appearance="Secondary"
                       Padding="8,4"
                       Click="OnAddPhase" />
        </Grid>
        <TextBlock Text="{Binding [State.Attribute.PhasesHint], Source={x:Static loc:Loc.Instance}}"
                   FontSize="11"
                   Foreground="Gray"
                   Margin="0,0,0,8" />
        <ItemsControl ItemsSource="{Binding Phases}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,6"
                            Padding="8,6"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding Expression}"
                                               FontSize="11"
                                               Foreground="Gray"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Content="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}"
                                               Appearance="Secondary"
                                               Padding="6,4"
                                               Margin="0,0,4,0"
                                               Click="OnEditPhase"
                                               Tag="{Binding}" />
                                    <ui:Button Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                               Appearance="Caution"
                                               Padding="6,4"
                                               Click="OnDeletePhase"
                                               Tag="{Binding}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding [Phase.Name], Source={x:Static loc:Loc.Instance}}"
                                               FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                        Foreground="Gray"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Binding [Phase.NamePlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                    <TextBlock Text="{Binding [Phase.Expression], Source={x:Static loc:Loc.Instance}}"
                                               FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                        Foreground="Gray"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Binding [Phase.ExpressionPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                    <TextBlock
                                        Text="{Binding [Phase.KnowledgeLink], Source={x:Static loc:Loc.Instance}}"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                        Foreground="Gray"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0" />
                                </StackPanel>
                                <components:MultiSelectComboBox ItemsSource="{Binding KnowledgeItems}"
                                                                DisplayMemberPath="DisplayWithType"
                                                                SelectedMemberPath="IsSelected"
                                                                Watermark="{Binding [Phase.KnowledgeLinkPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                                    <TextBlock
                                        Text="{Binding [Phase.EnterDirectives], Source={x:Static loc:Loc.Instance}}"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                        Foreground="Gray"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0" />
                                </StackPanel>
                                <components:DirectiveInputControl DirectiveInput="{Binding EnterDirectiveInput}" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                                    <TextBlock
                                        Text="{Binding [Phase.ExitDirectives], Source={x:Static loc:Loc.Instance}}"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                        Foreground="Gray"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0" />
                                </StackPanel>
                                <components:DirectiveInputControl DirectiveInput="{Binding ExitDirectiveInput}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
