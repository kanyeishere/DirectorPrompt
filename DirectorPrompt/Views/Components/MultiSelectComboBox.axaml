<UserControl x:Class="DirectorPrompt.Views.Components.MultiSelectComboBox"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <DropDownButton HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
        <TextBlock x:Name="SummaryTextBlock"
                   TextTrimming="CharacterEllipsis" />
        <DropDownButton.Flyout>
            <Flyout Placement="Bottom">
                <Border MinWidth="240" MaxHeight="360" Padding="4">
                    <ListBox ItemsSource="{Binding Options, ElementName=Root}"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Display}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Flyout>
        </DropDownButton.Flyout>
    </DropDownButton>
</UserControl>
