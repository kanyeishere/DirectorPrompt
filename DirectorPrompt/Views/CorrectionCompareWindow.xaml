<ui:FluentWindow x:Class="DirectorPrompt.Views.CorrectionCompareWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:diffplex="clr-namespace:DiffPlex.Wpf.Controls;assembly=DiffPlex.Wpf"
                 mc:Ignorable="d"
                 Width="1000"
                 Height="700"
                 MinWidth="600"
                 MinHeight="400"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="DialogTitleBar"
                     Grid.Row="0"
                     Margin="16,8,16,0"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <diffplex:DiffViewer x:Name="DiffView"
                             Grid.Row="1"
                             Margin="16,8,16,8"
                             IgnoreUnchanged="True"
                             HideLineNumbers="False" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8">
            <ui:Button x:Name="RejectButton"
                       Padding="20,6"
                       Margin="0,0,4,0"
                       Click="OnRejectClick" />
            <ui:Button x:Name="AcceptButton"
                       Padding="20,6"
                       Margin="4,0,0,0"
                       Appearance="Primary"
                       Click="OnAcceptClick" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
