<windowing:FAAppWindow x:Class="DirectorPrompt.Views.SettingsWindow"
                       xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:fa="using:FluentAvalonia.UI.Controls"
                       xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                       xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                       xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                       xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                       mc:Ignorable="d"
                       d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
                       Title="{Binding [Settings.Title], Source={x:Static loc:Loc.Instance}}"
                       Width="960"
                       Height="800"
                       MinWidth="600"
                       MinHeight="480"
                       Icon="/Assets/Images/Icon-NoBackground.ico"
                       TransparencyLevelHint="Mica">
    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     x:Name="NavList"
                     Background="{DynamicResource ControlFillColorTransparentBrush}"
                     BorderThickness="0"
                     Padding="4"
                     SelectionChanged="OnNavSelectionChanged"
                     SelectedIndex="0">
                <ListBoxItem Tag="providers" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Cloud" />
                        <TextBlock Text="{Binding [Settings.Provider.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="models" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="People" />
                        <TextBlock Text="{Binding [Settings.Model.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="prompts" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Document" />
                        <TextBlock Text="{Binding [Settings.Prompt.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="tasks" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Bullets" />
                        <TextBlock Text="{Binding [Settings.Task.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="embedding" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Library" />
                        <TextBlock Text="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="memory" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="SaveLocal" />
                        <TextBlock Text="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="retrieval" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Find" />
                        <TextBlock Text="{Binding [Knowledge.Retrieval.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="others" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Setting" />
                        <TextBlock Text="{Binding [Settings.Others.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <!-- 提供商面板 -->
                        <StackPanel x:Name="ProvidersPanel" IsVisible="True">
                            <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Provider.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Command="{Binding AddProviderCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Providers}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8" IsExpanded="True">
                                            <Expander.Header>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding Provider}"
                                                                   Foreground="#569CD6"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Padding="6,4"
                                                            Margin="0,0,-16,0"
                                                            Click="OnRemoveProvider"
                                                            Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Delete" />
                                                            <TextBlock
                                                                Text="{Binding [Common.Remove], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Expander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Provider.DisplayName], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding DisplayName}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Provider.Provider], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:PathComboBox Grid.Column="1"
                                                                             ItemsSource="{x:Static vm:ProviderSettingViewModel.AvailableProviders}"
                                                                             SelectedItem="{Binding Provider}"
                                                                             HorizontalAlignment="Stretch" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Provider.Endpoint], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Endpoint}"
                                                             PlaceholderText="{Binding [Settings.Agent.Placeholder.Endpoint], Source={x:Static loc:Loc.Instance}}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.APIKey], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding APIKey}"
                                                             PlaceholderText="{Binding [Settings.Agent.Placeholder.APIKey], Source={x:Static loc:Loc.Instance}}" />
                                                </Grid>

                                                <StackPanel Margin="0, 8">
                                                    <TextBlock
                                                        Text="{Binding [Settings.Provider.CustomHeaders], Source={x:Static loc:Loc.Instance}}"
                                                        Margin="0,0,0,6" />
                                                    <TextBox
                                                        Text="{Binding CustomHeaders}"
                                                        AcceptsReturn="True"
                                                        TextWrapping="Wrap"
                                                        MinHeight="80"
                                                        MaxHeight="200"
                                                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                        PlaceholderText='{}{"X-Custom-Header": "value"}' />
                                                </StackPanel>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 模型面板 -->
                        <StackPanel x:Name="ModelsPanel" IsVisible="False">
                            <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Model.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Command="{Binding AddModelCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Models}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8" IsExpanded="True">
                                            <Expander.Header>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding ModelName}"
                                                                   Foreground="#569CD6"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Padding="6,4"
                                                            Margin="0,0,-16,0"
                                                            Click="OnRemoveModel"
                                                            Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Delete" />
                                                            <TextBlock
                                                                Text="{Binding [Common.Remove], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Expander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Model.DisplayName], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding DisplayName}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Model.Provider], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:SearchableComboBox Grid.Column="1"
                                                            ItemsSource="{Binding DataContext.Providers, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            DisplayMemberPath="DisplayName"
                                                            SelectedValuePath="ID"
                                                            SelectedValue="{Binding ProviderID}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.ModelName], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:SearchableComboBox Grid.Column="1"
                                                            ItemsSource="{Binding AvailableModels}"
                                                            Text="{Binding ModelName}" />
                                                    <Button Grid.Column="2"
                                                            Padding="6,4"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding DataContext.FetchModelsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding IsFetchingModels, Converter={StaticResource InverseBool}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Download" />
                                                            <TextBlock
                                                                Text="{Binding [Settings.Agent.FetchModels], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <TextBlock Text="{Binding ModelFetchMessage}"
                                                           Margin="100,0,0,8"
                                                           TextWrapping="Wrap"
                                                           Foreground="Gray"
                                                           FontSize="12" />

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Agent.Temperature], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <fa:FANumberBox Grid.Column="1"
                                                                    Value="{Binding Temperature}"
                                                                    Minimum="0"
                                                                    Maximum="2"
                                                                    SmallChange="0.1"
                                                                    LargeChange="0.5"
                                                                    SpinButtonPlacementMode="Compact"
                                                                    HorizontalAlignment="Stretch" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Model.ReasoningEffort], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding ReasoningEffort}"
                                                             PlaceholderText="high" />
                                                </Grid>

                                                <StackPanel Margin="0, 8">
                                                    <TextBlock
                                                        Text="{Binding [Settings.Model.ExtraParameters], Source={x:Static loc:Loc.Instance}}"
                                                        Margin="0,0,0,6" />
                                                    <TextBox
                                                        Text="{Binding ExtraParameters}"
                                                        AcceptsReturn="True"
                                                        TextWrapping="Wrap"
                                                        MinHeight="120"
                                                        MaxHeight="300"
                                                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                        Margin="0,0,0,8"
                                                        PlaceholderText='{}{"top_p": 0.9}' />
                                                </StackPanel>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Model.Prompt], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:SearchableComboBox Grid.Column="1"
                                                            ItemsSource="{Binding DataContext.Prompts, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            DisplayMemberPath="DisplayName"
                                                            SelectedValuePath="ID"
                                                            SelectedValue="{Binding PromptID}" />
                                                    <Button Grid.Column="2"
                                                            Content="{Binding [Common.Clear], Source={x:Static loc:Loc.Instance}}"
                                                            Padding="6,4"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding DataContext.ClearModelPromptCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>


                                                <StackPanel Margin="0, 8"
                                                            Orientation="Horizontal">

                                                    <Button
                                                        Padding="8,4"
                                                        Command="{Binding DataContext.TestModelConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBool}}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Link" />
                                                            <TextBlock
                                                                Text="{Binding [Settings.Agent.TestConnection], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>

                                                    <TextBlock Text="{Binding ConnectionMessage}"
                                                               Margin="16,0,0,0"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"
                                                               FontSize="12" />

                                                </StackPanel>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 提示词面板 -->
                        <StackPanel x:Name="PromptsPanel" IsVisible="False">
                            <Grid Margin="0,0,0,12" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Prompt.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Command="{Binding AddPromptCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Prompts}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8">
                                            <Expander.Header>
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                            Padding="6,4"
                                                            Margin="0,0,-16,0"
                                                            Click="OnRemovePrompt"
                                                            Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Delete" />
                                                            <TextBlock
                                                                Text="{Binding [Common.Remove], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Expander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Prompt.DisplayName], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding DisplayName}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Prompt.Content], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Top" />
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Content}"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="120"
                                                             MaxHeight="300"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 代理任务面板 -->
                        <StackPanel x:Name="TasksPanel" IsVisible="False">
                            <TextBlock Text="{Binding [Settings.Task.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />

                            <ItemsControl ItemsSource="{Binding AgentTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8" IsExpanded="True">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding TaskTypeDisplay}"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Expander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Task.Model], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:SearchableComboBox Grid.Column="1"
                                                            ItemsSource="{Binding DataContext.Models, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            DisplayMemberPath="DisplayName"
                                                            SelectedValuePath="ID"
                                                            SelectedValue="{Binding ModelConfigID}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8" ColumnDefinitions="100,*,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Settings.Task.Prompt], Source={x:Static loc:Loc.Instance}}"
                                                               VerticalAlignment="Center" />
                                                    <components:SearchableComboBox Grid.Column="1"
                                                            ItemsSource="{Binding DataContext.Prompts, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            DisplayMemberPath="DisplayName"
                                                            SelectedValuePath="ID"
                                                            SelectedValue="{Binding PromptID}" />
                                                    <Button Grid.Column="2"
                                                            Content="{Binding [Common.Clear], Source={x:Static loc:Loc.Instance}}"
                                                            Padding="6,4"
                                                            Margin="8,0,0,0"
                                                            Command="{Binding DataContext.ClearTaskPromptCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 向量模型面板 -->
                        <StackPanel x:Name="EmbeddingPanel" IsVisible="False">
                            <TextBlock Text="{Binding [Settings.Embedding.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock
                                Text="{Binding [Settings.Embedding.Description], Source={x:Static loc:Loc.Instance}}"
                                FontSize="12" Foreground="Gray" Margin="0,0,0,16" />

                            <Grid Margin="0,0,0,8" ColumnDefinitions="100,*">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Model.Provider], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <components:SearchableComboBox Grid.Column="1"
                                                               ItemsSource="{Binding Providers}"
                                                               DisplayMemberPath="DisplayName"
                                                               SelectedValuePath="ID"
                                                               SelectedValue="{Binding Embedding.ProviderID}" />
                            </Grid>

                            <Grid Margin="0,0,0,8" ColumnDefinitions="100,*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Settings.Agent.ModelName], Source={x:Static loc:Loc.Instance}}"
                                           VerticalAlignment="Center" />
                                <components:SearchableComboBox Grid.Column="1"
                                                               ItemsSource="{Binding Embedding.AvailableModels}"
                                                               Text="{Binding Embedding.ModelName}" />
                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Command="{Binding FetchEmbeddingModelsCommand}"
                                        IsEnabled="{Binding Embedding.IsFetchingModels, Converter={StaticResource InverseBool}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Download" />
                                        <TextBlock
                                            Text="{Binding [Settings.Agent.FetchModels], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding Embedding.ModelFetchMessage}"
                                       Margin="100,0,0,8"
                                       TextWrapping="Wrap"
                                       Foreground="Gray"
                                       FontSize="12" />

                            <StackPanel Orientation="Horizontal">

                                <Button
                                    Command="{Binding TestEmbeddingConnectionCommand}"
                                    IsEnabled="{Binding Embedding.IsTestingConnection, Converter={StaticResource InverseBool}}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Link" />
                                        <TextBlock
                                            Text="{Binding [Settings.Agent.TestConnection], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                                <TextBlock
                                    Text="{Binding Embedding.ConnectionMessage}"
                                    TextWrapping="Wrap"
                                    VerticalAlignment="Center"
                                    FontSize="12" />

                            </StackPanel>

                        </StackPanel>

                        <!-- 记忆配置面板 -->
                        <StackPanel x:Name="MemoryPanel" IsVisible="False">
                            <TextBlock Text="{Binding [Memory.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.RecallTopK], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Memory.RecallTopK}"
                                            Minimum="1"
                                            Maximum="100"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.TokenBudget], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Memory.TokenBudget}"
                                            Minimum="100"
                                            Maximum="10000"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Memory.MinRelevance], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Memory.MinRelevance}"
                                            Minimum="0"
                                            Maximum="1"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Memory.TimeDecayLambda], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Memory.TimeDecayLambda}"
                                            Minimum="0"
                                            Maximum="1"
                                            HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- 知识检索配置面板 -->
                        <StackPanel x:Name="RetrievalPanel" IsVisible="False">
                            <TextBlock
                                Text="{Binding [Knowledge.Retrieval.ConfigTitle], Source={x:Static loc:Loc.Instance}}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.SemanticTopK], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Knowledge.SemanticTopK}"
                                            Minimum="1"
                                            Maximum="100"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.TokenBudget], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Knowledge.TokenBudget}"
                                            Minimum="100"
                                            Maximum="10000"
                                            Margin="0,0,0,12"
                                            HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Knowledge.Retrieval.MinRelevance], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <fa:FANumberBox Value="{Binding Knowledge.MinRelevance}"
                                            Minimum="0"
                                            Maximum="1"
                                            HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- 其他面板 -->
                        <StackPanel x:Name="OthersPanel" IsVisible="False">
                            <TextBlock Text="{Binding [Settings.Others.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock
                                    Text="{Binding [Settings.Language.Title], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                            <components:SearchableComboBox ItemsSource="{Binding AvailableLanguages}"
                                                           DisplayMemberPath="Value"
                                                           SelectedValuePath="Key"
                                                           SelectedValue="{Binding SelectedLanguage}"
                                                           HorizontalAlignment="Stretch"
                                                           Margin="0,0,0,12" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid ColumnDefinitions="*,Auto">

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Click="OnCancelClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Dismiss" />
                            <TextBlock Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnSaveClick" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Save" />
                            <TextBlock Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</windowing:FAAppWindow>
