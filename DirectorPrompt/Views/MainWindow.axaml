<windowing:FAAppWindow x:Class="DirectorPrompt.Views.MainWindow"
                       xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:fa="using:FluentAvalonia.UI.Controls"
                       xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                       xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                       xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                       xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                       mc:Ignorable="d"
                       d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
                       Title="DirectorPrompt"
                       Width="1280"
                       Height="800"
                       MinWidth="960"
                       MinHeight="600"
                       Icon="/Assets/Images/Icon-NoBackground.ico"
                       TransparencyLevelHint="Mica">
    <windowing:FAAppWindow.Styles>
        <Style Selector="Button.sidebar-toggle">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.sidebar-toggle:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle fa|FASymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle:pointerover fa|FASymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle:pressed">
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </windowing:FAAppWindow.Styles>
    <Grid x:Name="RootLayout" RowDefinitions="Auto,*">
        <Grid.Styles>
            <Style Selector="Grid#ProjectActions">
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
            <Style Selector="ComboBox#ProjectComboBox">
                <Setter Property="Width" Value="300" />
            </Style>
            <Style Selector="Button#LanSharingButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Button#LanSharingButton.lanactive">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="ToggleButton#MobileSessionsToggle">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="ToggleButton#MobileMoreActionsButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="ToggleButton#MobileDetailsToggle">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#ConversationPanel">
                <Setter Property="Grid.Column" Value="1" />
            </Style>
            <Style Selector="Border#SessionSidebar">
                <Setter Property="Width" Value="240" />
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Border#SessionSidebar.expanded">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="components|MessageRail#MobileMessageRail">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="TabControl#DetailsPanel">
                <Setter Property="Grid.Column" Value="3" />
                <Setter Property="Margin" Value="8,4,8,8" />
            </Style>
            <Style Selector="Button#CollapseSidebarButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Button#CollapseSidebarButton.expanded">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Button#ExpandSidebarButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Button#ExpandSidebarButton.collapsed">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile TextBlock#ProjectLabel">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#EditProjectButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#NewProjectButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#ImportButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#LanSharingButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#SettingsButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile ToggleButton#MobileSessionsToggle">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile ToggleButton#MobileMoreActionsButton">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile ToggleButton#MobileDetailsToggle">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Grid#ProjectActions">
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile ComboBox#ProjectComboBox">
                <Setter Property="Width" Value="NaN" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Grid#ConversationPanel">
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.ColumnSpan" Value="4" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Border#SessionSidebar">
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.ColumnSpan" Value="4" />
                <Setter Property="Panel.ZIndex" Value="10" />
                <Setter Property="Width" Value="320" />
                <Setter Property="IsVisible"
                        Value="{Binding IsChecked, ElementName=MobileSessionsToggle, Converter={StaticResource BoolToVisibility}}" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile GridSplitter#WorkspaceSplitter">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile TabControl#DetailsPanel">
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.ColumnSpan" Value="4" />
                <Setter Property="Panel.ZIndex" Value="10" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="IsVisible"
                        Value="{Binding IsChecked, ElementName=MobileDetailsToggle, Converter={StaticResource BoolToVisibility}}" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile components|MessageRail#MessageRail">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile components|MessageRail#MobileMessageRail">
                <Setter Property="IsVisible" Value="True" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#CollapseSidebarButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="Grid#RootLayout.mobile Button#ExpandSidebarButton">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="ToggleButton.mobile-nav-item">
                <Setter Property="Height" Value="52" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
            <Style Selector="ToggleButton.mobile-nav-item:checked">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            </Style>
        </Grid.Styles>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">

                <ToggleButton x:Name="MobileSessionsToggle"
                              Grid.Column="0"
                              Width="36"
                              Height="36"
                              Padding="0"
                              Margin="0,0,8,0"
                              Click="OnMobileSessionsToggleClick"
                              ToolTip.Tip="{Binding [Navigation.Sessions], Source={x:Static loc:Loc.Instance}}">
                    <fa:FASymbolIcon Symbol="List" FontSize="18" />
                </ToggleButton>

                <Grid x:Name="ProjectActions" Grid.Column="1"
                      ColumnDefinitions="Auto,*,Auto,Auto,Auto" VerticalAlignment="Center">
                    <TextBlock x:Name="ProjectLabel"
                               Grid.Column="0"
                               Text="{Binding [Navigation.Project], Source={x:Static loc:Loc.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <components:PathComboBox x:Name="ProjectComboBox"
                                             Grid.Column="1"
                                             Margin="0,0,4,0"
                                             ItemsSource="{Binding Projects}"
                                             DisplayMemberPath="Name"
                                             SelectedItem="{Binding CurrentProject}"
                                             IsEnabled="{Binding IsNotProcessing}" />
                    <Button x:Name="EditProjectButton"
                            Grid.Column="2"
                            Padding="12,6"
                            Margin="0,0,4,0"
                            Command="{Binding EditProjectCommand}"
                            IsEnabled="{Binding CanInteractProject}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Edit" />
                            <TextBlock Text="{Binding [Navigation.EditProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NewProjectButton"
                            Grid.Column="3"
                            Padding="12,6"
                            Command="{Binding NewProjectCommand}"
                            IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Add" />
                            <TextBlock Text="{Binding [Navigation.NewProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton"
                            Grid.Column="4"
                            Padding="12,6"
                            Margin="4,0,0,0"
                            Click="OnImportButtonClick"
                            IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Import" />
                            <TextBlock Text="{Binding [Navigation.ImportProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem
                                    Header="{Binding [Navigation.ImportDirectorPrompt], Source={x:Static loc:Loc.Instance}}"
                                    Click="OnImportDirectorPrompt" />
                                <MenuItem
                                    Header="{Binding [Navigation.ImportSillyTavern], Source={x:Static loc:Loc.Instance}}"
                                    Click="OnImportSillyTavern" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <Button x:Name="LanSharingButton"
                        Grid.Column="2"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Command="{Binding OpenLanSharingCommand}"
                        Classes.lanactive="{Binding LanSharingService.IsActive}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Link" />
                        <TextBlock Text="{Binding LanSharingService.Endpoint.Authority}" />
                    </StackPanel>
                </Button>

                <Button x:Name="SettingsButton"
                        Grid.Column="3"
                        Padding="12,6"
                        Command="{Binding OpenSettingsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Settings" />
                        <TextBlock Text="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}" />
                    </StackPanel>
                </Button>

                <ToggleButton x:Name="MobileMoreActionsButton"
                              Grid.Column="4"
                              Width="36"
                              Height="36"
                              Padding="0"
                              Margin="8,0,0,0"
                              ToolTip.Tip="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}">
                    <fa:FASymbolIcon Symbol="MoreVertical" FontSize="18" />
                </ToggleButton>

                <ToggleButton x:Name="MobileDetailsToggle"
                              Grid.Column="5"
                              Width="36"
                              Height="36"
                              Padding="0"
                              Margin="8,0,0,0"
                              Click="OnMobileDetailsToggleClick"
                              ToolTip.Tip="{Binding [Navigation.Details], Source={x:Static loc:Loc.Instance}}">
                    <fa:FASymbolIcon Symbol="ViewAll" FontSize="18" />
                </ToggleButton>
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SessionSidebar"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Classes.expanded="{Binding IsSessionSidebarExpanded}">
                <Grid RowDefinitions="Auto,*">

                    <Button Grid.Row="0"
                            Command="{Binding NewSessionCommand}"
                            IsEnabled="{Binding CanInteractProject}"
                            Margin="0,8,8,12"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Add" />
                            <TextBlock Text="{Binding [Navigation.NewSession], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding CurrentSession}"
                             SelectionChanged="OnSessionSelectionChanged"
                             IsEnabled="{Binding CanInteractProject}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid x:Name="ConversationPanel" RowDefinitions="Auto,*,Auto">

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding PipelineStages}"
                              Margin="16,4,16,4"
                              IsVisible="{Binding ShowPipelineStages, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Stage}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="1" ClipToBounds="False" RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">

                    <Button Grid.Row="0"
                            Grid.Column="0"
                            Margin="16,8,8,0"
                            HorizontalAlignment="Center"
                            Click="OnLoadEarlierDialog"
                            IsVisible="{Binding HasEarlierDialogEntries}"
                            IsEnabled="{Binding IsLoadingEarlierDialog, Converter={StaticResource InverseBool}}">
                        <TextBlock Text="{Binding [Dialog.LoadEarlier], Source={x:Static loc:Loc.Instance}}" />
                    </Button>

                    <ListBox x:Name="DialogListBox"
                             Grid.Row="1"
                             Grid.Column="0"
                             ItemsSource="{Binding Dialog.Entries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="16,8,8,8"
                             Focusable="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          HorizontalContentAlignment="Stretch" />
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                            <Style Selector="Border.message.director">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                            </Style>
                            <Style Selector="Border.message.error">
                                <Setter Property="Background"
                                        Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                            </Style>
                            <Style Selector="Border.message-actions">
                                <Setter Property="Width" Value="0" />
                                <Setter Property="Opacity" Value="0" />
                                <Setter Property="ClipToBounds" Value="True" />
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <DoubleTransition Property="Width"
                                                          Duration="0:0:0.18"
                                                          Easing="QuadraticEaseOut" />
                                        <DoubleTransition Property="Opacity"
                                                          Duration="0:0:0.14" />
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="Border.message-actions.open">
                                <Setter Property="Width" Value="90" />
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                            <Style Selector="Border.message-actions Button">
                                <Setter Property="Width" Value="26" />
                                <Setter Property="Height" Value="26" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style Selector="Button.message-menu">
                                <Setter Property="Width" Value="28" />
                                <Setter Property="Height" Value="28" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="message"
                                        Classes.director="{Binding IsDirector}"
                                        Classes.error="{Binding HasError}"
                                        Margin="0,6"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        MaxWidth="720"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Grid ColumnDefinitions="Auto,*,Auto">

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Role}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <Border x:Name="MessageActionsPanel"
                                                        Classes="message-actions"
                                                        Classes.open="{Binding IsMenuOpen}"
                                                        IsHitTestVisible="{Binding IsMenuOpen}"
                                                        Height="28"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0">
                                                    <StackPanel Orientation="Horizontal" Spacing="6" Width="90">
                                                        <Button Tag="{Binding}"
                                                                Click="OnCopyEntry"
                                                                ToolTip.Tip="{Binding [Common.Copy], Source={x:Static loc:Loc.Instance}}">
                                                            <fa:FASymbolIcon Symbol="Copy" />
                                                        </Button>
                                                        <Button Tag="{Binding}"
                                                                Click="OnEditEntry"
                                                                ToolTip.Tip="{Binding [Dialog.Edit], Source={x:Static loc:Loc.Instance}}">
                                                            <fa:FASymbolIcon Symbol="Edit" />
                                                        </Button>
                                                        <Button Tag="{Binding}"
                                                                Click="OnRollbackRound"
                                                                ToolTip.Tip="{Binding [Dialog.Rollback], Source={x:Static loc:Loc.Instance}}">
                                                            <fa:FASymbolIcon Symbol="Undo" />
                                                        </Button>
                                                    </StackPanel>
                                                </Border>
                                                <Button x:Name="MessageMenuButton"
                                                        Classes="message-menu"
                                                        Classes.open="{Binding IsMenuOpen}"
                                                        Click="OnMoreButtonClick"
                                                        Tag="{Binding}"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{Binding DataContext.IsNotProcessing, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                    <fa:FASymbolIcon Symbol="MoreVertical" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Expander
                                            Header="{Binding [Dialog.ThinkingProcess], Source={x:Static loc:Loc.Instance}}"
                                            IsVisible="{Binding HasThinking}"
                                            Margin="0,4,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                            <TextBlock Text="{Binding Thinking}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0" />
                                        </Expander>

                                        <!-- 内容区域: 四种状态重叠, 同一时刻只显示一个 -->
                                        <Grid Margin="0,4,0,0">
                                            <!-- 错误状态: 显示错误信息 -->
                                            <StackPanel
                                                IsVisible="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                                                <StackPanel Orientation="Horizontal">

                                                    <TextBlock Text="{Binding ErrorMessage}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                               VerticalAlignment="Top" />
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 导演指令: 按指令分块渲染 Markdown -->
                                            <ItemsControl ItemsSource="{Binding DirectorBlocks}"
                                                          IsVisible="{Binding ShowDirectorContent}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,4"
                                                                Padding="8,6"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TypeDisplay}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           Margin="0,0,0,2" />
                                                                <components:LiveMarkdownView
                                                                    Markdown="{Binding Content}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 叙事输出: 已渲染 Markdown 与尚未渲染的流式文本尾部同时显示 -->
                                            <StackPanel IsVisible="{Binding ShowNarrativeContent}">
                                                <components:LiveMarkdownView Markdown="{Binding Content}" />
                                            </StackPanel>

                                            <!-- 编辑模式: TextBox 替换正文 -->
                                            <StackPanel
                                                IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <TextBox
                                                    Text="{Binding EditingContent}"
                                                    AcceptsReturn="True"
                                                    TextWrapping="Wrap"
                                                    MinHeight="100"
                                                    Margin="0,0,0,4" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button
                                                        Padding="12,6"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Save" />
                                                            <TextBlock
                                                                Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                        Padding="12,6"
                                                        Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Dismiss" />
                                                            <TextBlock
                                                                Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <components:MessageRail x:Name="MessageRail"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Entries="{Binding Dialog.Entries}"
                                            TargetListBox="{Binding ElementName=DialogListBox}"
                                            MaxHeight="400"
                                            VerticalAlignment="Center"
                                            Margin="0,8,4,8" />

                    <components:MessageRail x:Name="MobileMessageRail"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Classes="mobile"
                                            Entries="{Binding Dialog.Entries}"
                                            TargetListBox="{Binding ElementName=DialogListBox}"
                                            Width="40"
                                            MaxHeight="264"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,8,4,8" />
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <components:DirectiveInputControl DirectiveInput="{Binding DirectiveInput}"
                                                          ShowSendButton="True"
                                                          SendCommand="{Binding SendDirectivesCommand}"
                                                          IsProcessing="{Binding IsProcessing}" />
                    </StackPanel>
                </Border>

            </Grid>

            <GridSplitter x:Name="WorkspaceSplitter"
                          Grid.Column="2"
                          Width="3"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <TabControl x:Name="DetailsPanel"
                        Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                        BorderThickness="0">

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                        <StackPanel>
                            <Expander Header="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                      IsExpanded="True"
                                      Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,2" ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding [State.Panel.Scene], Source={x:Static loc:Loc.Instance}}"
                                                   Foreground="Gray" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2" ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                               FontWeight="SemiBold"
                                                               Margin="8,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <Expander
                                Header="{Binding [Directive.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                IsExpanded="True"
                                Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2"
                                                    Padding="8,4"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Type}" Margin="0,0,4,0"
                                                                   DockPanel.Dock="Left" VerticalAlignment="Top" />
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                                   VerticalAlignment="Top" />
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding TTLLabel}"
                                                               FontSize="11"
                                                               Foreground="Gray"
                                                               IsVisible="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>


                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="{Binding [Character.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*">

                        <TextBox Grid.Row="0"
                                 Text="{Binding CharacterPanel.SearchText}"
                                 PlaceholderText="{Binding [Character.Panel.SearchPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                 Margin="0,0,0,6" />

                        <components:PathComboBox Grid.Row="1"
                                                 ItemsSource="{Binding CharacterPanel.AvailableCategories}"
                                                 SelectedItem="{Binding CharacterPanel.SelectedCategory, Mode=TwoWay}"
                                                 HorizontalAlignment="Stretch"
                                                 Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CharacterPanel.Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4"
                                                Padding="0"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <!-- 分组标题栏 -->
                                                <ToggleButton IsChecked="{Binding IsExpanded}"
                                                              Cursor="Hand"
                                                              Padding="14,10"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="HeaderBg"
                                                                    Background="Transparent"
                                                                    CornerRadius="6,6,0,0"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid ColumnDefinitions="Auto,*,Auto">

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding CategoryName}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="13"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Border Grid.Column="2"
                                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                            CornerRadius="8"
                                                                            Padding="6,1"
                                                                            VerticalAlignment="Center"
                                                                            Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                FontSize="11"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="White" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <!-- 人物条目列表 -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="10,0,10,10"
                                                              IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,3, 0, 3"
                                                                    Padding="12, 10, 12, 10"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <StackPanel Grid.Column="0"
                                                                                Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                    FontWeight="SemiBold"
                                                                                    Margin="0,0,8,0" />
                                                                        </StackPanel>
                                                                        <ToggleButton Grid.Column="1"
                                                                                IsChecked="{Binding IsExpanded}"
                                                                                Padding="0"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Center">
                                                                            <ToggleButton.Template>
                                                                                <ControlTemplate
                                                                                    TargetType="ToggleButton" />
                                                                            </ToggleButton.Template>
                                                                        </ToggleButton>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="12"
                                                                               Foreground="Gray"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock IsVisible="False"
                                                                               Text="{Binding Categories}"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                               Margin="0,4,0,0" />

                                                                    <StackPanel
                                                                        IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                                        Margin="0,8,0,0">
                                                                        <TextBlock
                                                                            Text="{Binding [Character.Panel.StateHeader], Source={x:Static loc:Loc.Instance}}"
                                                                            FontSize="11"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                            Margin="0,0,0,4"
                                                                            IsVisible="{Binding HasStateValues, Converter={StaticResource BoolToVisibility}}" />
                                                                        <ItemsControl
                                                                            ItemsSource="{Binding StateValues}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Grid Margin="0,2"
                                                                                        ColumnDefinitions="*,Auto">
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Text="{Binding Name}"
                                                                                            FontSize="11"
                                                                                            TextTrimming="CharacterEllipsis" />
                                                                                        <TextBlock Grid.Column="1"
                                                                                            Text="{Binding Value}"
                                                                                            FontSize="11"
                                                                                            FontWeight="SemiBold"
                                                                                            Margin="8,0,0,0" />
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>

                                                                        <TextBlock
                                                                            Text="{Binding [Character.Panel.RelationsHeader], Source={x:Static loc:Loc.Instance}}"
                                                                            FontSize="11"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                            Margin="0,8,0,4"
                                                                            IsVisible="{Binding HasRelations, Converter={StaticResource BoolToVisibility}}" />
                                                                        <ItemsControl ItemsSource="{Binding Relations}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock FontSize="11"
                                                                                        TextWrapping="Wrap">
                                                                                        <Run Text="{Binding Direction}" />
                                                                                        <Run Text="{Binding Target}"
                                                                                            FontWeight="SemiBold" />
                                                                                        <Run Text=": " />
                                                                                        <Run Text="{Binding Type}" />
                                                                                    </TextBlock>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>


                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="{Binding [Memory.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,8,0,0" RowDefinitions="Auto,Auto,*">


                        <TextBox Grid.Row="0"
                                 Text="{Binding MemoryPanel.SearchText}"
                                 PlaceholderText="{Binding [Memory.Panel.SearchPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                 Margin="0,0,0,6" />


                        <Grid Grid.Row="1" Margin="0,0,0,8" ColumnDefinitions="*,8,*">
                            <components:PathComboBox Grid.Column="0"
                                                     ItemsSource="{Binding MemoryPanel.AvailableScenes}"
                                                     SelectedItem="{Binding MemoryPanel.SelectedScene, Mode=TwoWay}"
                                                     MinWidth="0"
                                                     HorizontalAlignment="Stretch" />
                            <components:PathComboBox Grid.Column="2"
                                                     ItemsSource="{Binding MemoryPanel.AvailableTags}"
                                                     SelectedItem="{Binding MemoryPanel.SelectedTag, Mode=TwoWay}"
                                                     MinWidth="0"
                                                     HorizontalAlignment="Stretch" />
                        </Grid>


                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MemoryPanel.Groups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4"
                                                Padding="0"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <!-- 分组标题栏 -->
                                                <ToggleButton IsChecked="{Binding IsExpanded}"
                                                              Cursor="Hand"
                                                              Padding="14,10"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="HeaderBg"
                                                                    Background="Transparent"
                                                                    CornerRadius="6,6,0,0"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid ColumnDefinitions="Auto,*,Auto">

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding SceneLabel}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="13"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Border Grid.Column="2"
                                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                            CornerRadius="8"
                                                                            Padding="6,1"
                                                                            VerticalAlignment="Center"
                                                                            Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                FontSize="11"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="White" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <!-- 记忆条目列表 -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="10,0,10,10"
                                                              IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,3"
                                                                    Padding="12,10"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>
                                                                    <!-- 非编辑模式 -->
                                                                    <StackPanel
                                                                        IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                                        <DockPanel>
                                                                            <TextBlock
                                                                                Text="{Binding UpdatedAtDisplay}"
                                                                                FontSize="10"
                                                                                Foreground="Gray"
                                                                                VerticalAlignment="Center"
                                                                                DockPanel.Dock="Left" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    HorizontalAlignment="Right"
                                                                                    DockPanel.Dock="Right">
                                                                                <Button
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnEditMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip.Tip="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}" />
                                                                                <Button
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnDeleteMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip.Tip="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}" />
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                        <TextBlock Text="{Binding Content}"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding TagsDisplay}"
                                                                                FontSize="11"
                                                                                Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0"
                                                                                IsVisible="{Binding HasTags, Converter={StaticResource BoolToVisibility}}" />
                                                                        <TextBlock Text="{Binding RelatedCharacters}"
                                                                                FontSize="11"
                                                                                Foreground="Gray"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0"
                                                                                IsVisible="{Binding HasRelatedCharacters, Converter={StaticResource BoolToVisibility}}" />
                                                                    </StackPanel>

                                                                    <!-- 编辑模式 -->
                                                                    <StackPanel
                                                                        IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBox
                                                                            Text="{Binding EditingContent}"
                                                                            AcceptsReturn="True"
                                                                            TextWrapping="Wrap"
                                                                            MinHeight="80" />
                                                                        <TextBox
                                                                            Text="{Binding EditingTags}"
                                                                            Margin="0,4,0,0"
                                                                            PlaceholderText="{Binding [Memory.Panel.TagsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                HorizontalAlignment="Right"
                                                                                Margin="0,4,0,0">
                                                                            <Button
                                                                                Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                                                                                Padding="12,6"
                                                                                Margin="0,0,4,0"
                                                                                Command="{Binding DataContext.SaveMemoryEditCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                                                CommandParameter="{Binding}" />
                                                                            <Button
                                                                                Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                                                                                Padding="12,6"
                                                                                Command="{Binding DataContext.CancelMemoryEditCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                                                CommandParameter="{Binding}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>

            <Button x:Name="CollapseSidebarButton"
                    Grid.Column="0"
                    Classes="sidebar-toggle"
                    Width="20"
                    Height="36"
                    Command="{Binding ToggleSessionSidebarCommand}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="236,0,0,0"
                    Classes.expanded="{Binding IsSessionSidebarExpanded}"
                    ToolTip.Tip="{Binding [Navigation.CollapseSidebar], Source={x:Static loc:Loc.Instance}}">
                <fa:FASymbolIcon Symbol="ChevronLeft" FontSize="12" />
            </Button>

            <Button x:Name="ExpandSidebarButton"
                    Grid.Column="0"
                    Classes="sidebar-toggle"
                    Width="20"
                    Height="36"
                    Command="{Binding ToggleSessionSidebarCommand}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="4,0,0,0"
                    Classes.collapsed="{Binding IsSessionSidebarExpanded, Converter={StaticResource InverseBool}}"
                    ToolTip.Tip="{Binding [Navigation.ExpandSidebar], Source={x:Static loc:Loc.Instance}}">
                <fa:FASymbolIcon Symbol="ChevronRight" FontSize="12" />
            </Button>

        </Grid>

        <Panel x:Name="MobileMoreActionsBackdrop"
               Grid.Row="0" Grid.RowSpan="2"
               Background="Transparent"
               ZIndex="99"
               IsVisible="{Binding IsChecked, ElementName=MobileMoreActionsButton, Converter={StaticResource BoolToVisibility}}"
               PointerPressed="OnMobileBackdropPointerPressed" />

        <Border x:Name="MobileMoreActionsMenu"
                Grid.Row="1"
                Width="220"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,0,12,0"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                ZIndex="100"
                Padding="4"
                IsVisible="{Binding IsChecked, ElementName=MobileMoreActionsButton, Converter={StaticResource BoolToVisibility}}">
            <Border.Styles>
                <Style Selector="Button.menu-item">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="Padding" Value="12,10" />
                    <Setter Property="CornerRadius" Value="4" />
                </Style>
                <Style Selector="Button.menu-item:pointerover">
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                </Style>
            </Border.Styles>
            <StackPanel Spacing="2">
                <Button Classes="menu-item" Command="{Binding EditProjectCommand}" Click="OnMobileMenuItemClick"
                        IsEnabled="{Binding CanInteractProject}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:FASymbolIcon Symbol="Edit" FontSize="16" />
                        <TextBlock Text="{Binding [Navigation.EditProject], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="menu-item" Command="{Binding NewProjectCommand}" Click="OnMobileMenuItemClick"
                        IsEnabled="{Binding IsNotProcessing}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:FASymbolIcon Symbol="Add" FontSize="16" />
                        <TextBlock Text="{Binding [Navigation.NewProject], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="menu-item" Click="OnMobileImportDirectorPromptClick"
                        IsEnabled="{Binding IsNotProcessing}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:FASymbolIcon Symbol="Import" FontSize="16" />
                        <TextBlock
                            Text="{Binding [Navigation.ImportDirectorPrompt], Source={x:Static loc:Loc.Instance}}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Classes="menu-item" Click="OnMobileImportSillyTavernClick"
                        IsEnabled="{Binding IsNotProcessing}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:FASymbolIcon Symbol="Import" FontSize="16" />
                        <TextBlock Text="{Binding [Navigation.ImportSillyTavern], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Border Height="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="4,4,4,4" />
                <Button Classes="menu-item" Command="{Binding OpenSettingsCommand}" Click="OnMobileMenuItemClick">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <fa:FASymbolIcon Symbol="Settings" FontSize="16" />
                        <TextBlock Text="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Panel x:Name="RemoteOverlay"
               Grid.Row="0"
               Grid.RowSpan="2"
               ZIndex="1000"
               IsVisible="False">
            <Canvas x:Name="RemotePopupLayer"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True" />
            <Border x:Name="RemoteImportMenu"
                    Width="260"
                    Padding="4"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    IsVisible="False">
                <Border.Styles>
                    <Style Selector="Button.menu-item">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                    <Style Selector="Button.menu-item:pointerover">
                        <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    </Style>
                </Border.Styles>
                <StackPanel Spacing="2">
                    <Button Classes="menu-item"
                            Click="OnRemoteImportDirectorPromptClick"
                            IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <fa:FASymbolIcon Symbol="Import" FontSize="16" />
                            <TextBlock Text="{Binding [Navigation.ImportDirectorPrompt], Source={x:Static loc:Loc.Instance}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="menu-item"
                            Click="OnRemoteImportSillyTavernClick"
                            IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <fa:FASymbolIcon Symbol="Import" FontSize="16" />
                            <TextBlock Text="{Binding [Navigation.ImportSillyTavern], Source={x:Static loc:Loc.Instance}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Panel>

    </Grid>
</windowing:FAAppWindow>
