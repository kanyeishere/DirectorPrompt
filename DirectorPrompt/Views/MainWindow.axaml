<windowing:FAAppWindow x:Class="DirectorPrompt.Views.MainWindow"
                 xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:fa="using:FluentAvalonia.UI.Controls"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                 xmlns:v="clr-namespace:DirectorPrompt.Views"
                 xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
                 Title="DirectorPrompt"
                 Width="1280"
                 Height="800"
                 MinWidth="960"
                 MinHeight="600"
                 Icon="/Assets/Images/Icon-NoBackground.png"
                 TransparencyLevelHint="Mica">
    <windowing:FAAppWindow.Styles>
        <Style Selector="Button.sidebar-toggle">
            <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.sidebar-toggle:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle fa|FASymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle:pointerover fa|FASymbolIcon">
            <Setter Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Button.sidebar-toggle:pressed">
            <Setter Property="BorderThickness" Value="2" />
        </Style>
    </windowing:FAAppWindow.Styles>
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding [Navigation.Project], Source={x:Static loc:Loc.Instance}}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <components:PathComboBox Width="300"
                              Margin="0,0,4,0"
                              ItemsSource="{Binding Projects}"
                              DisplayMemberPath="Name"
                              SelectedItem="{Binding CurrentProject}"
                              IsEnabled="{Binding IsNotProcessing}">
</components:PathComboBox>
                    <Button
                               Padding="12,6"
                               Margin="0,0,4,0"
                               Command="{Binding EditProjectCommand}"
                               IsEnabled="{Binding CanInteractProject}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Edit" />
                            <TextBlock Text="{Binding [Navigation.EditProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button
                               Padding="12,6"
                               Command="{Binding NewProjectCommand}"
                               IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Add" />
                            <TextBlock Text="{Binding [Navigation.NewProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ImportButton"
                               Padding="12,6"
                               Margin="4,0,0,0"
                               Click="OnImportButtonClick"
                               IsEnabled="{Binding IsNotProcessing}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Import" />
                            <TextBlock Text="{Binding [Navigation.ImportProject], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem
                                    Header="{Binding [Navigation.ImportDirectorPrompt], Source={x:Static loc:Loc.Instance}}"
                                    Click="OnImportDirectorPrompt" />
                                <MenuItem
                                    Header="{Binding [Navigation.ImportSillyTavern], Source={x:Static loc:Loc.Instance}}"
                                    Click="OnImportSillyTavern" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <Button Grid.Column="2"
                           Padding="12,6"
                           Command="{Binding OpenSettingsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <fa:FASymbolIcon Symbol="Settings" />
                        <TextBlock Text="{Binding [Navigation.Settings], Source={x:Static loc:Loc.Instance}}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="320" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="240"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,1,0"
                    IsVisible="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                               Command="{Binding NewSessionCommand}"
                               IsEnabled="{Binding CanInteractProject}"
                               Margin="0,8,8,12"
                               HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Add" />
                            <TextBlock Text="{Binding [Navigation.NewSession], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding CurrentSession}"
                             IsEnabled="{Binding CanInteractProject}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,0,8">
<ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding PipelineStages}"
                              Margin="16,4,16,4"
                              IsVisible="{Binding ShowPipelineStages, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10,4"
                                    CornerRadius="6">
<StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Stage}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="1" ClipToBounds="False">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="DialogListBox"
                             Grid.Column="0"
                             ItemsSource="{Binding Dialog.Entries}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="16,8,8,8"
                             Focusable="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          HorizontalContentAlignment="Stretch" />
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                            <Style Selector="Border.message.director">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                            </Style>
                            <Style Selector="Border.message.error">
                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="message"
                                        Classes.director="{Binding IsDirector}"
                                        Classes.error="{Binding HasError}"
                                        Margin="0,6"
                                        Padding="14,10"
                                        CornerRadius="8"
                                        MaxWidth="720"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Role}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Top" />

                                            <Button Grid.Column="2"
                                                    Click="OnMoreButtonClick"
                                                    Padding="6,2"
                                                    VerticalAlignment="Top"
                                            IsEnabled="{Binding DataContext.IsNotProcessing, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <fa:FASymbolIcon Symbol="MoreVertical" />
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem
                                                            Header="{Binding [Common.Copy], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnCopyEntry"
                                                            Tag="{Binding}" />
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Edit], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnEditEntry"
                                                            Tag="{Binding}" />
                                                        <MenuItem
                                                            Header="{Binding [Dialog.Rollback], Source={x:Static loc:Loc.Instance}}"
                                                            Click="OnRollbackRound"
                                                            Tag="{Binding}" />
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                            </Button>
                                        </Grid>

                                        <Expander
                                            Header="{Binding [Dialog.ThinkingProcess], Source={x:Static loc:Loc.Instance}}"
                                            IsVisible="{Binding HasThinking}"
                                            Margin="0,4,0,0"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}">
<TextBlock Text="{Binding Thinking}"
                                                       TextWrapping="Wrap"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0" />
                                        </Expander>

                                        <!-- 内容区域: 四种状态重叠, 同一时刻只显示一个 -->
                                        <Grid Margin="0,4,0,0">
                                            <!-- 错误状态: 显示错误信息 -->
                                            <StackPanel
                                                IsVisible="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                                                <StackPanel Orientation="Horizontal">
                                                    
                                                    <TextBlock Text="{Binding ErrorMessage}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                               VerticalAlignment="Top" />
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- 导演指令: 按指令分块渲染 Markdown -->
                                            <ItemsControl ItemsSource="{Binding DirectorBlocks}"
                                                          IsVisible="{Binding ShowDirectorContent}">
<ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,4"
                                                                Padding="8,6"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TypeDisplay}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           Margin="0,0,0,2" />
                                                                <components:LiveMarkdownView Markdown="{Binding Content}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 叙事输出: 已渲染 Markdown 与尚未渲染的流式文本尾部同时显示 -->
                                            <StackPanel IsVisible="{Binding ShowNarrativeContent}">
<components:LiveMarkdownView Markdown="{Binding Content}" />
                                            </StackPanel>

                                            <!-- 编辑模式: TextBox 替换正文 -->
                                            <StackPanel
                                                IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                <TextBox
                                                    Text="{Binding EditingContent}"
                                                    AcceptsReturn="True"
                                                    TextWrapping="Wrap"
                                                    MinHeight="100"
                                                    Margin="0,0,0,4" />
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button
                                                        Padding="12,6"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Save" />
                                                            <TextBlock Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Button
                                                        Padding="12,6"
                                                        Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Dismiss" />
                                                            <TextBlock Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <components:MessageRail Grid.Column="1"
                                            Entries="{Binding Dialog.Entries}"
                                            TargetListBox="{Binding ElementName=DialogListBox}"
                                            MaxHeight="400"
                                            VerticalAlignment="Center"
                                            Margin="0,8,4,8" />
                </Grid>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <components:DirectiveInputControl DirectiveInput="{Binding DirectiveInput}"
                                                          ShowSendButton="True"
                                                          SendCommand="{Binding SendDirectivesCommand}"
                                                          IsProcessing="{Binding IsProcessing}" />
                    </StackPanel>
                </Border>

            </Grid>

            <GridSplitter Grid.Column="2"
                          Width="3"
                          Background="{DynamicResource ControlElevationBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <TabControl Grid.Column="3"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="8,4,8,8">

                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            
                            <TextBlock Text="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                        <StackPanel>
                            <Expander Header="{Binding [State.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                             IsExpanded="True"
                                             Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding [State.Panel.Scene], Source={x:Static loc:Loc.Instance}}"
                                                   Foreground="Gray" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding StatePanel.CurrentSceneLabel}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding StatePanel.StateItems}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                               FontWeight="SemiBold"
                                                               Margin="8,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <Expander
                                Header="{Binding [Directive.Panel.Title], Source={x:Static loc:Loc.Instance}}"
                                IsExpanded="True"
                                Margin="0,0,0,8">
                                <ItemsControl ItemsSource="{Binding DirectivesPanel.Directives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2"
                                                    Padding="8,4"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    CornerRadius="4">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock Text="{Binding Type}" Margin="0,0,4,0" DockPanel.Dock="Left" VerticalAlignment="Top" />
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" VerticalAlignment="Top" />
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding TTLLabel}"
                                                               FontSize="11"
                                                               Foreground="Gray"
                                                               IsVisible="{Binding HasTTL, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>


                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            
                            <TextBlock Text="{Binding [Character.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                    Text="{Binding CharacterPanel.SearchText}"
                                    PlaceholderText="{Binding [Character.Panel.SearchPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                    Margin="0,0,0,6" />

                        <components:PathComboBox Grid.Row="1"
                                  ItemsSource="{Binding CharacterPanel.AvailableCategories}"
                                  SelectedItem="{Binding CharacterPanel.SelectedCategory, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,8" />

                        <ScrollViewer Grid.Row="2" ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CharacterPanel.Groups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4"
                                                Padding="0"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <!-- 分组标题栏 -->
                                                <ToggleButton IsChecked="{Binding IsExpanded}"
                                                              Cursor="Hand"
                                                              Padding="14,10"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="HeaderBg"
                                                                    Background="Transparent"
                                                                    CornerRadius="6,6,0,0"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding CategoryName}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="13"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Border Grid.Column="2"
                                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                            CornerRadius="8"
                                                                            Padding="6,1"
                                                                            VerticalAlignment="Center"
                                                                            Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                FontSize="11"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="White" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <!-- 人物条目列表 -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="10,0,10,10"
                                                              IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,3, 0, 3"
                                                                    Padding="12, 10, 12, 10"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0"
                                                                                Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Name}"
                                                                                    FontWeight="SemiBold"
                                                                                    Margin="0,0,8,0" />
                                                                        </StackPanel>
                                                                        <ToggleButton Grid.Column="1"
                                                                                IsChecked="{Binding IsExpanded}"
                                                                                Padding="0"
                                                                                Cursor="Hand"
                                                                                VerticalAlignment="Center">
                                                                            <ToggleButton.Template>
                                                                                <ControlTemplate
                                                                                    TargetType="ToggleButton">
                                                                                    
                                                                                    
                                                                                </ControlTemplate>
                                                                            </ToggleButton.Template>
                                                                        </ToggleButton>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="12"
                                                                               Foreground="Gray"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock IsVisible="False"
                                                                               Text="{Binding Categories}"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                               Margin="0,4,0,0" />

                                                                    <StackPanel
                                                                        IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"
                                                                        Margin="0,8,0,0">
                                                                        <TextBlock
                                                                            Text="{Binding [Character.Panel.StateHeader], Source={x:Static loc:Loc.Instance}}"
                                                                            FontSize="11"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                            Margin="0,0,0,4"
                                                                            IsVisible="{Binding HasStateValues, Converter={StaticResource BoolToVisibility}}" />
                                                                        <ItemsControl
                                                                            ItemsSource="{Binding StateValues}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Grid Margin="0,2">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*" />
                                                                                            <ColumnDefinition
                                                                                                Width="Auto" />
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0"
                                                                                            Text="{Binding Name}"
                                                                                            FontSize="11"
                                                                                            TextTrimming="CharacterEllipsis" />
                                                                                        <TextBlock Grid.Column="1"
                                                                                            Text="{Binding Value}"
                                                                                            FontSize="11"
                                                                                            FontWeight="SemiBold"
                                                                                            Margin="8,0,0,0" />
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>

                                                                        <TextBlock
                                                                            Text="{Binding [Character.Panel.RelationsHeader], Source={x:Static loc:Loc.Instance}}"
                                                                            FontSize="11"
                                                                            FontWeight="SemiBold"
                                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                            Margin="0,8,0,4"
                                                                            IsVisible="{Binding HasRelations, Converter={StaticResource BoolToVisibility}}" />
                                                                        <ItemsControl ItemsSource="{Binding Relations}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock FontSize="11"
                                                                                        TextWrapping="Wrap">
                                                                                        <Run Text="{Binding Direction}" />
                                                                                        <Run Text="{Binding Target}"
                                                                                            FontWeight="SemiBold" />
                                                                                        <Run Text=": " />
                                                                                        <Run Text="{Binding Type}" />
                                                                                    </TextBlock>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>


                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            
                            <TextBlock Text="{Binding [Memory.Panel.Title], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>


                        <TextBox Grid.Row="0"
                                    Text="{Binding MemoryPanel.SearchText}"
                                    PlaceholderText="{Binding [Memory.Panel.SearchPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                    Margin="0,0,0,6" />


                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <components:PathComboBox Grid.Column="0"
                                      ItemsSource="{Binding MemoryPanel.AvailableScenes}"
                                      SelectedItem="{Binding MemoryPanel.SelectedScene, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                            <components:PathComboBox Grid.Column="2"
                                      ItemsSource="{Binding MemoryPanel.AvailableTags}"
                                      SelectedItem="{Binding MemoryPanel.SelectedTag, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                        </Grid>


                        <ScrollViewer Grid.Row="2"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MemoryPanel.Groups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4"
                                                Padding="0"
                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <StackPanel>
                                                <!-- 分组标题栏 -->
                                                <ToggleButton IsChecked="{Binding IsExpanded}"
                                                              Cursor="Hand"
                                                              Padding="14,10"
                                                              HorizontalAlignment="Stretch"
                                                              HorizontalContentAlignment="Stretch">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="HeaderBg"
                                                                    Background="Transparent"
                                                                    CornerRadius="6,6,0,0"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding SceneLabel}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="13"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <Border Grid.Column="2"
                                                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                            CornerRadius="8"
                                                                            Padding="6,1"
                                                                            VerticalAlignment="Center"
                                                                            Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding ItemCount}"
                                                                                FontSize="11"
                                                                                FontWeight="SemiBold"
                                                                                Foreground="White" />
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <!-- 记忆条目列表 -->
                                                <ItemsControl ItemsSource="{Binding Items}"
                                                              Margin="10,0,10,10"
                                                              IsVisible="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,3"
                                                                    Padding="12,10"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="4">
                                                                <StackPanel>
                                                                    <!-- 非编辑模式 -->
                                                                    <StackPanel
                                                                        IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                                                                        <DockPanel>
                                                                            <TextBlock
                                                                                Text="{Binding UpdatedAtDisplay}"
                                                                                FontSize="10"
                                                                                Foreground="Gray"
                                                                                VerticalAlignment="Center"
                                                                                DockPanel.Dock="Left" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    HorizontalAlignment="Right"
                                                                                    DockPanel.Dock="Right">
                                                                                <Button
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnEditMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip.Tip="{Binding [Common.Edit], Source={x:Static loc:Loc.Instance}}">
                                                                                    
                                                                                </Button>
                                                                                <Button
                                                                                    Padding="6,2"
                                                                                    Margin="4,0,0,0"
                                                                                    Click="OnDeleteMemory"
                                                                                    Tag="{Binding}"
                                                                                    ToolTip.Tip="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}">
                                                                                    
                                                                                </Button>
                                                                            </StackPanel>
                                                                        </DockPanel>
                                                                        <TextBlock Text="{Binding Content}"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding TagsDisplay}"
                                                                                FontSize="11"
                                                                                Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0"
                                                                                IsVisible="{Binding HasTags, Converter={StaticResource BoolToVisibility}}" />
                                                                        <TextBlock Text="{Binding RelatedCharacters}"
                                                                                FontSize="11"
                                                                                Foreground="Gray"
                                                                                TextWrapping="Wrap"
                                                                                Margin="0,4,0,0"
                                                                                IsVisible="{Binding HasRelatedCharacters, Converter={StaticResource BoolToVisibility}}" />
                                                                    </StackPanel>

                                                                    <!-- 编辑模式 -->
                                                                    <StackPanel
                                                                        IsVisible="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                                        <TextBox
                                                                            Text="{Binding EditingContent}"
                                                                            AcceptsReturn="True"
                                                                            TextWrapping="Wrap"
                                                                            MinHeight="80" />
                                                                        <TextBox
                                                                            Text="{Binding EditingTags}"
                                                                            Margin="0,4,0,0"
                                                                            PlaceholderText="{Binding [Memory.Panel.TagsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                HorizontalAlignment="Right"
                                                                                Margin="0,4,0,0">
                                                                            <Button
                                                                                Content="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}"
                                                                                Padding="12,6"
                                                                                Margin="0,0,4,0"
                                                                                Command="{Binding DataContext.SaveMemoryEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                            <Button
                                                                                Content="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}"
                                                                                Padding="12,6"
                                                                                Command="{Binding DataContext.CancelMemoryEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>

            <Button Grid.Column="0"
                       Classes="sidebar-toggle"
                       Width="20"
                       Height="36"
                       Command="{Binding ToggleSessionSidebarCommand}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="236,0,0,0"
                       IsVisible="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}}"
                       ToolTip.Tip="{Binding [Navigation.CollapseSidebar], Source={x:Static loc:Loc.Instance}}">
                <fa:FASymbolIcon Symbol="ChevronLeft" FontSize="12" />
            </Button>

            <Button Grid.Column="0"
                       Classes="sidebar-toggle"
                       Width="20"
                       Height="36"
                       Command="{Binding ToggleSessionSidebarCommand}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       IsVisible="{Binding IsSessionSidebarExpanded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                       ToolTip.Tip="{Binding [Navigation.ExpandSidebar], Source={x:Static loc:Loc.Instance}}">
                <fa:FASymbolIcon Symbol="ChevronRight" FontSize="12" />
            </Button>
        </Grid>

    </Grid>
</windowing:FAAppWindow>
