<ui:FluentWindow x:Class="DirectorPrompt.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 xmlns:enums="clr-namespace:DirectorPrompt.Domain.Enums;assembly=DirectorPrompt.Domain"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
                 Title="全局设置"
                 Width="760"
                 Height="600"
                 MinWidth="600"
                 MinHeight="480"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <converters:EnumDisplayConverter x:Key="EnumDisplay" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <Style TargetType="ListViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="全局设置" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0"
                      x:Name="NavList"
                      Background="{DynamicResource ControlFillColorTransparentBrush}"
                      BorderThickness="0"
                      Padding="4"
                      SelectionChanged="OnNavSelectionChanged"
                      SelectedIndex="0">
                <ListViewItem Tag="database" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Database24" Margin="0,0,12,0" />
                        <TextBlock Text="数据库" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="agents" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Bot24" Margin="0,0,12,0" />
                        <TextBlock Text="Agent 配置" VerticalAlignment="Center" />
                    </StackPanel>
                </ListViewItem>
            </ListView>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <StackPanel x:Name="DatabasePanel" Visibility="Visible">
                            <TextBlock Text="数据库"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="数据库路径"
                                           VerticalAlignment="Center" />
                                <ui:TextBox Grid.Column="1"
                                            Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="快照间隔"
                                           VerticalAlignment="Center" />
                                <ui:NumberBox Grid.Column="1"
                                              Value="{Binding SnapshotInterval, UpdateSourceTrigger=PropertyChanged}"
                                              Minimum="0"
                                              Maximum="1000" />
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="AgentsPanel" Visibility="Collapsed">
                            <TextBlock Text="Agent 配置"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="每个 Agent 可独立配置模型和温度"
                                       FontSize="12"
                                       Foreground="Gray"
                                       Margin="0,0,0,16" />

                            <ItemsControl ItemsSource="{Binding Agents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CardExpander Margin="0,0,0,8" IsExpanded="True">
                                            <ui:CardExpander.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding RoleDisplay}"
                                                               Foreground="Gray"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding ModelName}"
                                                               Foreground="#569CD6"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </ui:CardExpander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="名称" VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Margin="0,0,8,0"
                                                                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Grid.Column="2" Text="角色" VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="3"
                                                              ItemsSource="{Binding Source={x:Type enums:AgentRole}, Converter={StaticResource EnumDisplay}}"
                                                              SelectedItem="{Binding Role, Converter={StaticResource EnumDisplay}}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Provider"
                                                               VerticalAlignment="Center" />
                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{x:Static vm:AgentSettingViewModel.AvailableProviders}"
                                                              SelectedItem="{Binding Provider}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Endpoint"
                                                               VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="留空使用默认值" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="API Key"
                                                               VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Text="{Binding APIKey, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="本地模型可留空" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="模型名" VerticalAlignment="Center" />
                                                    <ui:TextBox Grid.Column="1"
                                                                Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" />
                                                </Grid>

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="温度" VerticalAlignment="Center" />
                                                    <ui:NumberBox Grid.Column="1"
                                                                  Margin="0,0,8,0"
                                                                  Value="{Binding Temperature}"
                                                                  Minimum="0"
                                                                  Maximum="2"
                                                                  SpinButtonPlacementMode="Compact" />
                                                    <TextBlock Grid.Column="2" Text="重试次数" VerticalAlignment="Center" />
                                                    <ui:NumberBox Grid.Column="3"
                                                                  Value="{Binding MaxRetries}"
                                                                  Minimum="0"
                                                                  Maximum="10"
                                                                  SpinButtonPlacementMode="Compact" />
                                                </Grid>

                                                <CheckBox Content="启用"
                                                          IsChecked="{Binding Enabled}"
                                                          Margin="0,4,0,0" />

                                                <ui:Button Content="测试连接"
                                                           Icon="PlugConnected24"
                                                           Appearance="Secondary"
                                                           Margin="0,12,0,0"
                                                           Command="{Binding DataContext.TestAgentConnectionCommand, RelativeSource={RelativeSource AncestorType=ui:FluentWindow}}"
                                                           CommandParameter="{Binding}"
                                                           IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InverseBool}}" />

                                                <TextBlock Text="{Binding ConnectionMessage}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap"
                                                           FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="Gray" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ConnectionSuccess}"
                                                                             Value="True">
                                                                    <Setter Property="Foreground" Value="#107C10" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ConnectionSuccess}"
                                                                             Value="False">
                                                                    <Setter Property="Foreground" Value="OrangeRed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <ui:Button Content="关闭"
                               Margin="0,0,8,0"
                               Click="OnCloseClick" />
                    <ui:Button Content="保存"
                               Appearance="Primary"
                               Click="OnSaveClick"
                               IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
