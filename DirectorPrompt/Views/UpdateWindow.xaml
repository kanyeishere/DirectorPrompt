<ui:FluentWindow x:Class="DirectorPrompt.Views.UpdateWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 Title="{Binding [Update.Title], Source={x:Static loc:Loc.Instance}}"
                 Width="420"
                 Height="180"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterScreen">
    <StackPanel>
        <ui:TitleBar Margin="24,8,24,0"
                     ShowMaximize="False"
                     ShowClose="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/Images/Icon-NoBackground.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="24,16,24,8">
            <ui:ProgressRing x:Name="ProgressRing"
                             IsIndeterminate="True"
                             Width="32"
                             Height="32"
                             Margin="0,0,12,0" />

            <ui:TextBlock x:Name="StatusText"
                          FontSize="14"
                          VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
