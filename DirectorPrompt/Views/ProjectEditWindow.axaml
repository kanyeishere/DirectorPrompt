<windowing:FAAppWindow x:Class="DirectorPrompt.Views.ProjectEditWindow"
                 xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:fa="using:FluentAvalonia.UI.Controls"
                 xmlns:vm="clr-namespace:DirectorPrompt.ViewModels"
                 xmlns:converters="clr-namespace:DirectorPrompt.Converters"
                 xmlns:loc="clr-namespace:DirectorPrompt.Localization"
                 xmlns:components="clr-namespace:DirectorPrompt.Views.Components"
                 xmlns:windowing="using:FluentAvalonia.UI.Windowing"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=vm:ProjectEditViewModel}"
                 Title="{Binding [Project.EditTitle], Source={x:Static loc:Loc.Instance}}"
                 Width="1000"
                 Height="720"
                 MinWidth="800"
                 MinHeight="600"
                 Icon="/Assets/Images/Icon-NoBackground.png"
                 TransparencyLevelHint="Mica">
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                      x:Name="NavList"
                      Background="{DynamicResource ControlFillColorTransparentBrush}"
                      BorderThickness="0"
                      Padding="4"
                      SelectionChanged="OnNavSelectionChanged"
                      SelectedIndex="0">
                <ListBoxItem Tag="basic" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Edit" />
                        <TextBlock Text="{Binding [Project.Basic.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="knowledge" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="Library" />
                        <TextBlock Text="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="state" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="View" />
                        <TextBlock Text="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="character" Padding="12,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <fa:FASymbolIcon Symbol="People" />
                        <TextBlock Text="{Binding [Character.Title], Source={x:Static loc:Loc.Instance}}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <Grid>
                        <!-- 基本信息 -->
                        <StackPanel x:Name="BasicPanel" IsVisible="True">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Project.Basic.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Command="{Binding ExportProjectCommand}"
                                           IsEnabled="{Binding IsEditing}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Upload" />
                                        <TextBlock Text="{Binding [Navigation.ExportProject], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding [Project.Basic.Name], Source={x:Static loc:Loc.Instance}}"
                                           FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBox Text="{Binding Name}"
                                        PlaceholderText="{Binding [Project.Basic.NamePlaceholder], Source={x:Static loc:Loc.Instance}}" />

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                                <TextBlock
                                    Text="{Binding [Project.Basic.Description], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBox Text="{Binding Description}"
                                        PlaceholderText="{Binding [Project.Basic.DescriptionPlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        MinHeight="100"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto" />

                            <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                                <TextBlock
                                    Text="{Binding [Project.Basic.OpeningMessage], Source={x:Static loc:Loc.Instance}}"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                    Foreground="Gray"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBox Text="{Binding OpeningMessage}"
                                        PlaceholderText="{Binding [Project.Basic.OpeningMessagePlaceholder], Source={x:Static loc:Loc.Instance}}"
                                        AcceptsReturn="True"
                                        TextWrapping="Wrap"
                                        MinHeight="80"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <!-- 知识系统 (树状) -->
                        <StackPanel x:Name="KnowledgePanel" IsVisible="False">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Knowledge.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Command="{Binding AddKnowledgeGroupCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding KnowledgeGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8" IsExpanded="True">
                                            <Expander.Header>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1"
                                                                Margin="0, 0, -16, 0"
                                                                Orientation="Horizontal">
                                                        <Button Padding="6,4" Click="OnDeleteKnowledgeGroup" Tag="{Binding}">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <fa:FASymbolIcon Symbol="Delete" />
                                                                <TextBlock Text="删除" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Expander.Header>

                                            <StackPanel>

                                                <CheckBox
                                                    Content="{Binding [Knowledge.Group.Enable], Source={x:Static loc:Loc.Instance}}"
                                                    IsChecked="{Binding Active}"
                                                    Margin="0,-4,0,8" />

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock
                                                        Text="{Binding [Knowledge.Group.Name], Source={x:Static loc:Loc.Instance}}"
                                                        FontWeight="SemiBold" />
                                                    <TextBlock
                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                        Foreground="Gray"
                                                        FontSize="12"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0" />
                                                </StackPanel>
                                                <TextBox Text="{Binding Name}"
                                                            PlaceholderText="{Binding [Knowledge.Group.NamePlaceholder], Source={x:Static loc:Loc.Instance}}"
                                                            Margin="0,0,0,12" />
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock
                                                        Text="{Binding [Knowledge.Group.Description], Source={x:Static loc:Loc.Instance}}"
                                                        FontWeight="SemiBold" />
                                                    <TextBlock
                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                        Foreground="Gray"
                                                        FontSize="12"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0" />
                                                </StackPanel>
                                                <TextBox
                                                    Text="{Binding Description}"
                                                    PlaceholderText="{Binding [Knowledge.Group.PlaceholderOptional], Source={x:Static loc:Loc.Instance}}"
                                                    Margin="0,0,0,12" />

                                                <Grid Margin="0,8,0,8">
                                                     <Grid.ColumnDefinitions>
                                                         <ColumnDefinition Width="*" />
                                                         <ColumnDefinition Width="Auto" />
                                                     </Grid.ColumnDefinitions>
                                                     <TextBlock Grid.Column="0"
                                                                Text="{Binding [Knowledge.Entry.Title], Source={x:Static loc:Loc.Instance}}"
                                                                FontWeight="SemiBold"
                                                                VerticalAlignment="Center" />
                                                     <Button Grid.Column="1"
                                                             Padding="6,4"
                                                             Command="{Binding DataContext.AddKnowledgeEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             CommandParameter="{Binding}">
                                                         <StackPanel Orientation="Horizontal" Spacing="6">
                                                             <fa:FASymbolIcon Symbol="Add" />
                                                             <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                                         </StackPanel>
                                                     </Button>
                                                 </Grid>
                                                <ItemsControl ItemsSource="{Binding Entries}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                             <Expander Margin="0,0,0,6" IsExpanded="{Binding IsEditing, Mode=TwoWay}">
                                                                 <Expander.Header>
                                                                     <Grid>
                                                                         <Grid.ColumnDefinitions>
                                                                             <ColumnDefinition Width="*" />
                                                                             <ColumnDefinition Width="Auto" />
                                                                         </Grid.ColumnDefinitions>
                                                                         <TextBlock Grid.Column="0"
                                                                                 Text="{Binding Remarks}"
                                                                                 FontWeight="SemiBold"
                                                                                 VerticalAlignment="Center" />
                                                                         <Button Grid.Column="1"
                                                                                 Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                                                 Padding="6,4"
                                                                                 Margin="0,0,-16,0"
                                                                                 Click="OnDeleteKnowledgeEntry"
                                                                                 Tag="{Binding}" />
                                                                     </Grid>
                                                                 </Expander.Header>
                                                                 <StackPanel>
                                                             <StackPanel>

                                                                        <CheckBox
                                                                            Content="{Binding [Knowledge.Entry.Active], Source={x:Static loc:Loc.Instance}}"
                                                                            IsChecked="{Binding Active}"
                                                                            Margin="0,8,0,4" />

                                                                        <StackPanel Orientation="Horizontal"
                                                                                Margin="0,8,0,4">
                                                                            <TextBlock
                                                                                Text="{Binding [Knowledge.Entry.RemarksLabel], Source={x:Static loc:Loc.Instance}}" />
                                                                            <TextBlock
                                                                                Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                Foreground="Gray"
                                                                                FontSize="12"
                                                                                VerticalAlignment="Center"
                                                                                Margin="8,0,0,0" />
                                                                        </StackPanel>
                                                                        <TextBox
                                                                            Text="{Binding Remarks}" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                Margin="0,8,0,4">
                                                                            <TextBlock
                                                                                Text="{Binding [Knowledge.Entry.Content], Source={x:Static loc:Loc.Instance}}" />
                                                                            <TextBlock
                                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                Foreground="Gray"
                                                                                FontSize="12"
                                                                                VerticalAlignment="Center"
                                                                                Margin="8,0,0,0" />
                                                                        </StackPanel>
                                                                        <TextBox
                                                                            Text="{Binding Content}"
                                                                            AcceptsReturn="True"
                                                                            TextWrapping="Wrap"
                                                                            MinHeight="80"
                                                                            ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                                                        <StackPanel Orientation="Horizontal"
                                                                                Margin="0,8,0,4">
                                                                            <TextBlock
                                                                                Text="{Binding [Knowledge.Entry.Keywords], Source={x:Static loc:Loc.Instance}}" />
                                                                            <TextBlock
                                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                Foreground="Gray"
                                                                                FontSize="12"
                                                                                VerticalAlignment="Center"
                                                                                Margin="8,0,0,0" />
                                                                        </StackPanel>
                                                                        <TextBox
                                                                            Text="{Binding Keywords}"
                                                                            PlaceholderText="{Binding [Knowledge.Entry.KeywordsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                             </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 状态系统 -->
                        <StackPanel x:Name="StatePanel" IsVisible="False">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [State.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Command="{Binding AddStateAttributeCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Common.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding StateAttributes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                         <Expander Margin="0,2" IsExpanded="{Binding IsEditing, Mode=TwoWay}">
                                             <Expander.Header>
                                                 <Grid>
                                                     <Grid.ColumnDefinitions>
                                                         <ColumnDefinition Width="*" />
                                                         <ColumnDefinition Width="Auto" />
                                                     </Grid.ColumnDefinitions>
                                                     <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                         <TextBlock Text="{Binding DisplayName}"
                                                                    FontWeight="SemiBold"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" />
                                                         <TextBlock Text="{Binding Name}"
                                                                    Foreground="Gray"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center" />
                                                     </StackPanel>
                                                     <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,-16,0">
                                                         <Button
                                                             Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                             Click="OnDeleteStateAttribute"
                                                             Tag="{Binding}" />
                                                     </StackPanel>
                                                 </Grid>
                                             </Expander.Header>
                                             <StackPanel>

                                             <StackPanel>
                                                    <Grid Margin="0,8,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock
                                                                    Text="{Binding [State.Attribute.Identifier], Source={x:Static loc:Loc.Instance}}" />
                                                                <TextBlock
                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                    Foreground="Gray"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                            </StackPanel>
                                                            <TextBox
                                                                Text="{Binding Name}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock
                                                                    Text="{Binding [State.Attribute.DisplayName], Source={x:Static loc:Loc.Instance}}" />
                                                                <TextBlock
                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                    Foreground="Gray"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                            </StackPanel>
                                                            <TextBox
                                                                Text="{Binding DisplayName}" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Grid Margin="0,4,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock
                                                                    Text="{Binding [State.Attribute.ValueType], Source={x:Static loc:Loc.Instance}}" />
                                                                <TextBlock
                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                    Foreground="Gray"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                            </StackPanel>
                                                            <components:PathComboBox
                                                                ItemsSource="{Binding ValueTypes, Source={x:Static vm:EnumOptions.Instance}}"
                                                                SelectedValue="{Binding ValueType}"
                                                                SelectedValuePath="Value"
                                                                DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="4,0,0,0"
                                                                    IsVisible="{Binding IsNumericConfig, Converter={StaticResource BoolToVisibility}}">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock
                                                                    Text="{Binding [State.Attribute.Driver], Source={x:Static loc:Loc.Instance}}" />
                                                                <TextBlock
                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                    Foreground="Gray"
                                                                    FontSize="12"
                                                                    VerticalAlignment="Center"
                                                                    Margin="8,0,0,0" />
                                                            </StackPanel>
                                                            <components:PathComboBox
                                                                ItemsSource="{Binding Drivers, Source={x:Static vm:EnumOptions.Instance}}"
                                                                SelectedValue="{Binding Driver}"
                                                                SelectedValuePath="Value"
                                                                DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- numeric + narrative -->
                                                    <StackPanel Margin="0,8,0,0"
                                                                IsVisible="{Binding IsNumericConfig, Converter={StaticResource BoolToVisibility}}">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.MinValue], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <fa:FANumberBox Value="{Binding MinValue}"
                                                                      Minimum="-999999"
                                                                      Maximum="999999"  HorizontalAlignment="Stretch" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.MaxValue], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <fa:FANumberBox Value="{Binding MaxValue}"
                                                                      Minimum="-999999"
                                                                      Maximum="999999"  HorizontalAlignment="Stretch" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.Unit], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <TextBox
                                                            Text="{Binding Unit}"
                                                            PlaceholderText="{Binding [State.Attribute.UnitPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.ChangeRules], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <TextBox
                                                            Text="{Binding ChangeRules}"
                                                            AcceptsReturn="True"
                                                            TextWrapping="Wrap"
                                                            MinHeight="60"
                                                            ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                                    </StackPanel>

                                                    <!-- enum + system -->
                                                    <StackPanel Margin="0,8,0,0"
                                                                IsVisible="{Binding IsEnumConfig, Converter={StaticResource BoolToVisibility}}">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.Options], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <TextBox
                                                            Text="{Binding Options}"
                                                            PlaceholderText="{Binding [State.Attribute.OptionsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                                            <TextBlock
                                                                Text="{Binding [State.Attribute.Trigger], Source={x:Static loc:Loc.Instance}}" />
                                                            <TextBlock
                                                                Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <components:PathComboBox
                                                            ItemsSource="{Binding SystemTriggers, Source={x:Static vm:EnumOptions.Instance}}"
                                                            SelectedValue="{Binding Trigger}"
                                                            SelectedValuePath="Value"
                                                            DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />

                                                        <ItemsControl ItemsSource="{Binding Transitions}"
                                                                      Margin="0,8,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,0,0,4" Padding="8,4"
                                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                            BorderThickness="1" CornerRadius="4">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding Option}"
                                                                                    FontWeight="SemiBold"
                                                                                    Margin="0,0,0,4" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.TransitionMethod.Method], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray" FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <components:PathComboBox
                                                                                ItemsSource="{Binding TransitionMethods, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                SelectedValue="{Binding Method}"
                                                                                SelectedValuePath="Value"
                                                                                DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />

                                                                            <StackPanel
                                                                                IsVisible="{Binding IsRandom, Converter={StaticResource BoolToVisibility}}"
                                                                                Margin="0,4,0,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.TransitionMethod.Probability], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray" FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <fa:FANumberBox Value="{Binding Weight}"
                                                                                    Minimum="0"  HorizontalAlignment="Stretch" />
                                                                            </StackPanel>

                                                                            <StackPanel
                                                                                IsVisible="{Binding IsExpression, Converter={StaticResource BoolToVisibility}}"
                                                                                Margin="0,4,0,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.TransitionMethod.Attribute], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray" FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <components:PathComboBox
                                                                                    ItemsSource="{Binding DataContext.AvailableNumericAttributes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    SelectedItem="{Binding AttributeName}"  HorizontalAlignment="Stretch" />
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.TransitionMethod.Expression], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray" FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <TextBox
                                                                                    Text="{Binding Expression}"
                                                                                    PlaceholderText="{Binding [State.TransitionMethod.ExpressionPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.TransitionMethod.SwitchMode], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray" FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <components:PathComboBox
                                                                                    ItemsSource="{Binding SwitchModes, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                    SelectedValue="{Binding SwitchMode}"
                                                                                    SelectedValuePath="Value"
                                                                                    DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                                            </StackPanel>

                                                                            <StackPanel
                                                                                IsVisible="{Binding IsOnce, Converter={StaticResource BoolToVisibility}}"
                                                                                Margin="0,4,0,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.TransitionMethod.Probability], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray" FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <fa:FANumberBox Value="{Binding Weight}"
                                                                                    Minimum="0"  HorizontalAlignment="Stretch" />
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <components:PhaseEditControl
                                                        PhaseSource="{Binding}"
                                                        AddPhaseCommand="{Binding DataContext.AddPhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        DeletePhaseCommand="{Binding DataContext.DeletePhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />

                                                </StackPanel>
                                            </StackPanel>
                                         </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                        <!-- 人物系统 -->
                        <StackPanel x:Name="CharacterPanel" IsVisible="False">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding [Character.Title], Source={x:Static loc:Loc.Instance}}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Command="{Binding AddCharacterCategoryCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <fa:FASymbolIcon Symbol="Add" />
                                        <TextBlock Text="{Binding [Character.Category.Add], Source={x:Static loc:Loc.Instance}}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding CharacterCategories}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,8" IsExpanded="False">
                                            <Expander.Header>
                                                 <Grid>
                                                     <Grid.ColumnDefinitions>
                                                         <ColumnDefinition Width="*" />
                                                         <ColumnDefinition Width="Auto" />
                                                     </Grid.ColumnDefinitions>
                                                     <TextBlock Grid.Column="0"
                                                                Text="{Binding Name}"
                                                                FontWeight="SemiBold"
                                                                VerticalAlignment="Center" />
                                                     <StackPanel Grid.Column="1"
                                                                 Orientation="Horizontal"
                                                                 Margin="0, 0, -16, 0">
                                                         <Button
                                                             Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                             Padding="6,4"
                                                             Click="OnDeleteCharacterCategory"
                                                             Tag="{Binding}" />
                                                     </StackPanel>
                                                 </Grid>
                                            </Expander.Header>

                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock
                                                                Text="{Binding [Character.Category.Name], Source={x:Static loc:Loc.Instance}}"
                                                                FontWeight="SemiBold" />
                                                            <TextBlock
                                                                Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray"
                                                                FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>
                                                        <TextBox
                                                            Text="{Binding Name}"
                                                            PlaceholderText="{Binding [Character.Category.NamePlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock
                                                                Text="{Binding [Character.Category.ParentCategories], Source={x:Static loc:Loc.Instance}}"
                                                                FontWeight="SemiBold"
                                                                Margin="0,0,0,4" />

                                                            <TextBlock
                                                                Text="{Binding [Character.Category.ParentCategories.Description], Source={x:Static loc:Loc.Instance}}"
                                                                Foreground="Gray" FontSize="12"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0,0,0" />
                                                        </StackPanel>

                                                        <components:MultiSelectComboBox
                                                            ItemsSource="{Binding AvailableParentCategories}"
                                                            DisplayMemberPath="Name"
                                                            SelectedMemberPath="IsSelected" />
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock
                                                        Text="{Binding [Character.Category.DescriptionLabel], Source={x:Static loc:Loc.Instance}}"
                                                        FontWeight="SemiBold" />
                                                    <TextBlock
                                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                        Foreground="Gray"
                                                        FontSize="12"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0" />
                                                </StackPanel>
                                                <TextBox
                                                    Text="{Binding Description}"
                                                    Margin="0,0,0,16" />

                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding [Character.Category.StateAttributes], Source={x:Static loc:Loc.Instance}}"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center" />
                                                    <Button Grid.Column="1"
                                                               Padding="8,4"
                                                               Click="OnAddCategoryStateAttribute"
                                                               Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <fa:FASymbolIcon Symbol="Add" />
                                                            <TextBlock Text="{Binding [Character.Category.AddAttribute], Source={x:Static loc:Loc.Instance}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding StateAttributes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                             <Expander Margin="0,0,0,6" IsExpanded="{Binding IsEditing, Mode=TwoWay}">
                                                                 <Expander.Header>
                                                                     <Grid>
                                                                         <Grid.ColumnDefinitions>
                                                                             <ColumnDefinition Width="*" />
                                                                             <ColumnDefinition Width="Auto" />
                                                                         </Grid.ColumnDefinitions>
                                                                         <StackPanel Grid.Column="0"
                                                                                 Orientation="Horizontal">
                                                                             <TextBlock Text="{Binding DisplayName}"
                                                                                     FontWeight="SemiBold"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="0,0,8,0" />
                                                                             <TextBlock Text="{Binding Name}"
                                                                                     Foreground="Gray"
                                                                                     FontSize="12"
                                                                                     VerticalAlignment="Center" />
                                                                         </StackPanel>
                                                                         <StackPanel Grid.Column="1"
                                                                                 Orientation="Horizontal" Margin="0,0,-16,0">
                                                                             <Button
                                                                                 Content="{Binding [Common.Delete], Source={x:Static loc:Loc.Instance}}"
                                                                                 Padding="6,4"
                                                                                 Click="OnDeleteStateAttribute"
                                                                                 Tag="{Binding}" />
                                                                         </StackPanel>
                                                                     </Grid>
                                                                 </Expander.Header>
                                                                 <StackPanel>

                                                                 <StackPanel>
                                                                        <Grid Margin="0,8,0,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0"
                                                                                    Margin="0,0,4,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.Attribute.Identifier], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray"
                                                                                        FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <TextBox
                                                                                    Text="{Binding Name}" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="1"
                                                                                    Margin="4,0,0,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.Attribute.DisplayName], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray"
                                                                                        FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <TextBox
                                                                                    Text="{Binding DisplayName}" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                        <Grid Margin="0,4,0,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <StackPanel Grid.Column="0"
                                                                                    Margin="0,0,4,0">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.Attribute.ValueType], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray"
                                                                                        FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <components:PathComboBox
                                                                                    ItemsSource="{Binding ValueTypes, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                    SelectedValue="{Binding ValueType}"
                                                                                    SelectedValuePath="Value"
                                                                                    DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                                            </StackPanel>
                                                                            <StackPanel Grid.Column="1"
                                                                                    Margin="4,0,0,0"
                                                                                    IsVisible="{Binding IsNumericConfig, Converter={StaticResource BoolToVisibility}}">
                                                                                <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                    <TextBlock
                                                                                        Text="{Binding [State.Attribute.Driver], Source={x:Static loc:Loc.Instance}}" />
                                                                                    <TextBlock
                                                                                        Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                        Foreground="Gray"
                                                                                        FontSize="12"
                                                                                        VerticalAlignment="Center"
                                                                                        Margin="8,0,0,0" />
                                                                                </StackPanel>
                                                                                <components:PathComboBox
                                                                                    ItemsSource="{Binding Drivers, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                    SelectedValue="{Binding Driver}"
                                                                                    SelectedValuePath="Value"
                                                                                    DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                                            </StackPanel>
                                                                        </Grid>

                                                                        <StackPanel Margin="0,8,0,0"
                                                                                IsVisible="{Binding IsNumericConfig, Converter={StaticResource BoolToVisibility}}">
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.MinValue], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <fa:FANumberBox Value="{Binding MinValue}"
                                                                                    Minimum="-999999"
                                                                                    Maximum="999999"  HorizontalAlignment="Stretch" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.MaxValue], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <fa:FANumberBox Value="{Binding MaxValue}"
                                                                                    Minimum="-999999"
                                                                                    Maximum="999999"  HorizontalAlignment="Stretch" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.Unit], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <TextBox
                                                                                Text="{Binding Unit}"
                                                                                PlaceholderText="{Binding [State.Attribute.UnitPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.ChangeRules], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.ParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <TextBox
                                                                                Text="{Binding ChangeRules}"
                                                                                AcceptsReturn="True"
                                                                                TextWrapping="Wrap"
                                                                                MinHeight="60"
                                                                                ScrollViewer.VerticalScrollBarVisibility="Auto" />
                                                                        </StackPanel>

                                                                        <StackPanel Margin="0,8,0,0"
                                                                                IsVisible="{Binding IsEnumConfig, Converter={StaticResource BoolToVisibility}}">
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.Options], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <TextBox
                                                                                Text="{Binding Options}"
                                                                                PlaceholderText="{Binding [State.Attribute.OptionsPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                            <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,8,0,4">
                                                                                <TextBlock
                                                                                    Text="{Binding [State.Attribute.Trigger], Source={x:Static loc:Loc.Instance}}" />
                                                                                <TextBlock
                                                                                    Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                    Foreground="Gray"
                                                                                    FontSize="12"
                                                                                    VerticalAlignment="Center"
                                                                                    Margin="8,0,0,0" />
                                                                            </StackPanel>
                                                                            <components:PathComboBox
                                                                                ItemsSource="{Binding SystemTriggers, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                SelectedValue="{Binding Trigger}"
                                                                                SelectedValuePath="Value"
                                                                                DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />

                                                                            <ItemsControl
                                                                                ItemsSource="{Binding Transitions}"
                                                                                Margin="0,8,0,0">
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Border Margin="0,0,0,4"
                                                                                            Padding="8,4"
                                                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                                            BorderThickness="1"
                                                                                            CornerRadius="4">
                                                                                            <StackPanel>
                                                                                                <TextBlock
                                                                                                    Text="{Binding Option}"
                                                                                                    FontWeight="SemiBold"
                                                                                                    Margin="0,0,0,4" />
                                                                                                <StackPanel
                                                                                                    Orientation="Horizontal"
                                                                                                    Margin="0,0,0,4">
                                                                                                    <TextBlock
                                                                                                        Text="{Binding [State.TransitionMethod.Method], Source={x:Static loc:Loc.Instance}}" />
                                                                                                    <TextBlock
                                                                                                        Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                        Foreground="Gray"
                                                                                                        FontSize="12"
                                                                                                        VerticalAlignment="Center"
                                                                                                        Margin="8,0,0,0" />
                                                                                                </StackPanel>
                                                                                                <components:PathComboBox
                                                                                                    ItemsSource="{Binding TransitionMethods, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                                    SelectedValue="{Binding Method}"
                                                                                                    SelectedValuePath="Value"
                                                                                                    DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />

                                                                                                <StackPanel
                                                                                                    IsVisible="{Binding IsRandom, Converter={StaticResource BoolToVisibility}}"
                                                                                                    Margin="0,4,0,0">
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,0,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.Probability], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <fa:FANumberBox
                                                                                                        Value="{Binding Weight}"
                                                                                                        Minimum="0"  HorizontalAlignment="Stretch" />
                                                                                                </StackPanel>

                                                                                                <StackPanel
                                                                                                    IsVisible="{Binding IsExpression, Converter={StaticResource BoolToVisibility}}"
                                                                                                    Margin="0,4,0,0">
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,0,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.Attribute], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <components:PathComboBox
                                                                                                        ItemsSource="{Binding DataContext.AvailableNumericAttributes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                                        SelectedItem="{Binding AttributeName}"  HorizontalAlignment="Stretch" />
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,8,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.Expression], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <TextBox
                                                                                                        Text="{Binding Expression}"
                                                                                                        PlaceholderText="{Binding [State.TransitionMethod.ExpressionPlaceholder], Source={x:Static loc:Loc.Instance}}" />
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,8,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.SwitchMode], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <components:PathComboBox
                                                                                                        ItemsSource="{Binding SwitchModes, Source={x:Static vm:EnumOptions.Instance}}"
                                                                                                        SelectedValue="{Binding SwitchMode}"
                                                                                                        SelectedValuePath="Value"
                                                                                                        DisplayMemberPath="Display"  HorizontalAlignment="Stretch" />
                                                                                                </StackPanel>

                                                                                                <StackPanel
                                                                                                    IsVisible="{Binding IsOnce, Converter={StaticResource BoolToVisibility}}"
                                                                                                    Margin="0,4,0,0">
                                                                                                    <StackPanel
                                                                                                        Orientation="Horizontal"
                                                                                                        Margin="0,0,0,4">
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [State.TransitionMethod.Probability], Source={x:Static loc:Loc.Instance}}" />
                                                                                                        <TextBlock
                                                                                                            Text="{Binding [Common.NotParticipatesInRetrieval], Source={x:Static loc:Loc.Instance}}"
                                                                                                            Foreground="Gray"
                                                                                                            FontSize="12"
                                                                                                            VerticalAlignment="Center"
                                                                                                            Margin="8,0,0,0" />
                                                                                                    </StackPanel>
                                                                                                    <fa:FANumberBox
                                                                                                        Value="{Binding Weight}"
                                                                                                        Minimum="0"  HorizontalAlignment="Stretch" />
                                                                                                </StackPanel>
                                                                                            </StackPanel>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </StackPanel>

                                                                        <components:PhaseEditControl
                                                                            PhaseSource="{Binding}"
                                                                            AddPhaseCommand="{Binding DataContext.AddPhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            DeletePhaseCommand="{Binding DataContext.DeletePhaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                             </Expander>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding ValidationMessage}"
                           Foreground="OrangeRed"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0" Click="OnCancelClick">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Dismiss" />
                            <TextBlock Text="{Binding [Common.Cancel], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnSaveClick" IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <fa:FASymbolIcon Symbol="Save" />
                            <TextBlock Text="{Binding [Common.Save], Source={x:Static loc:Loc.Instance}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</windowing:FAAppWindow>
