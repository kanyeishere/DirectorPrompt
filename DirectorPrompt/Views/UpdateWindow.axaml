<windowing:FAAppWindow x:Class="DirectorPrompt.Views.UpdateWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:windowing="using:FluentAvalonia.UI.Windowing"
        Width="480" SizeToContent="Height" CanResize="False"
        ShowAsDialog="True" Icon="/Assets/Images/Icon-NoBackground.png"
        WindowStartupLocation="CenterScreen" TransparencyLevelHint="Mica">
    <StackPanel Margin="24" Spacing="12">
        <TextBlock x:Name="StatusText" TextWrapping="Wrap" />
        <StackPanel x:Name="ProgressPanel" Spacing="8">
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" MinWidth="360" />
            <TextBlock x:Name="ProgressText" HorizontalAlignment="Center" IsVisible="False" />
        </StackPanel>
        <StackPanel x:Name="ErrorPanel" Spacing="12" IsVisible="False">
            <TextBlock x:Name="ErrorText" TextWrapping="Wrap" />
            <Button x:Name="CloseButton" HorizontalAlignment="Right" Click="OnCloseClick" />
        </StackPanel>
    </StackPanel>
</windowing:FAAppWindow>
