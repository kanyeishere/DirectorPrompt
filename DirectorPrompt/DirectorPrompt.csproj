<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Version>1.1.7</Version>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net10.0-windows10.0.18362.0</TargetFramework>
        <RootNamespace>DirectorPrompt</RootNamespace>
        <ApplicationIcon>..\Assets\Images\Icon-NoBackground.ico</ApplicationIcon>
        <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\DirectorPrompt.Agents\DirectorPrompt.Agents.csproj"/>
        <ProjectReference Include="..\DirectorPrompt.Domain\DirectorPrompt.Domain.csproj"/>
        <ProjectReference Include="..\DirectorPrompt.Infrastructure\DirectorPrompt.Infrastructure.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia"/>
        <PackageReference Include="Avalonia.Desktop"/>
        <PackageReference Include="CommunityToolkit.Mvvm"/>
        <PackageReference Include="CommunityToolkit.WinUI.Notifications"/>
        <PackageReference Include="DailyRoutines.CodeAnalysis">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="FluentAvaloniaUI"/>
        <PackageReference Include="LiveMarkdown.Avalonia"/>
        <PackageReference Include="Microsoft.Extensions.Configuration"/>
        <PackageReference Include="Microsoft.Extensions.Configuration.Json"/>
        <PackageReference Include="Microsoft.Extensions.Hosting"/>
        <PackageReference Include="Microsoft.Extensions.Options"/>
        <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions"/>
        <PackageReference Include="Serilog"/>
        <PackageReference Include="Serilog.Extensions.Hosting"/>
        <PackageReference Include="System.Drawing.Common"/>
        <PackageReference Include="Velopack"/>
    </ItemGroup>

    <ItemGroup>
        <None Update="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="..\Assets\Langs\*.json">
            <Link>Assets\Langs\%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Include="..\Assets\CHANGELOG.md">
            <Link>Assets\CHANGELOG.md</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <AvaloniaResource Include="..\Assets\Images\*.ico">
            <Link>Assets\Images\%(Filename)%(Extension)</Link>
        </AvaloniaResource>
        <AvaloniaResource Include="..\Assets\Images\*.png">
            <Link>Assets\Images\%(Filename)%(Extension)</Link>
        </AvaloniaResource>
    </ItemGroup>

</Project>
