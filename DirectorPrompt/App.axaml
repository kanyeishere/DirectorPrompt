<Application x:Class="DirectorPrompt.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.Styling"
             xmlns:converters="clr-namespace:DirectorPrompt.Converters"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <fa:FluentAvaloniaTheme PreferSystemTheme="False" />
        <StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml" />
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:NumberBoxValueConverter x:Key="NumberBoxValue" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
